---
interface Props {
	label: string;
	value: string;
	href?: string;
}

const { label, value, href } = Astro.props;
---

<div class="flex flex-col gap-1">
	<dt class="text-xs font-medium uppercase tracking-wider text-muted-foreground">{label}</dt>
	<dd class="text-sm text-foreground">
		{
			href ? (
				<a href={href} class="text-accent no-underline hover:text-accent-hover" target="_blank" rel="noopener noreferrer">
					{value}
				</a>
			) : (
				value
			)
		}
	</dd>
</div>
