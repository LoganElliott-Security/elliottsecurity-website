---
interface Props {
	label: string;
	value: string;
	href?: string;
}

const { label, value, href } = Astro.props;
const isExternal = Boolean(href?.startsWith('http://') || href?.startsWith('https://'));
---

<div class="meta-item">
	<dt class="meta-item__label">{label}</dt>
	<dd class="meta-item__value">
		{
			href ? (
				<a
					href={href}
					class="meta-item__link"
					target={isExternal ? '_blank' : undefined}
					rel={isExternal ? 'noopener noreferrer' : undefined}
				>
					{value}
				</a>
			) : (
				value
			)
		}
	</dd>
</div>

<style>
	.meta-item {
		display: flex;
		flex-direction: column;
		gap: var(--space-1);
		min-width: 0;
	}

	.meta-item__label {
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-wide);
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	.meta-item__value {
		margin: 0;
		font-size: var(--font-size-small);
		color: var(--color-text);
	}

	.meta-item__link {
		color: var(--color-accent);
		text-decoration: none;
		transition: var(--transition-hover);
	}

	.meta-item__link:hover {
		color: var(--color-soft);
	}
</style>
