---
import { cn } from '../../lib/cn';
import { getTagUrl } from '../../lib/knowledge';

interface Props {
	tags: string[];
	class?: string;
}

const { tags, class: className } = Astro.props;
---

{
	tags.length > 0 && (
		<ul class={cn('flex flex-wrap gap-2', className)} role="list">
			{tags.map((tag) => (
				<li>
					<a
						href={getTagUrl(tag)}
						class="rounded-full border border-border bg-surface-muted px-2.5 py-0.5 text-xs font-medium text-muted no-underline transition-colors hover:border-accent/40 hover:text-accent"
					>
						{tag}
					</a>
				</li>
			))}
		</ul>
	)
}
