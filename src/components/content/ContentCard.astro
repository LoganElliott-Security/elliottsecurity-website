---
import Card from '../ui/Card.astro';
import TagList from './TagList.astro';

interface Props {
	title: string;
	description: string;
	href: string;
	meta?: string;
	tags?: string[];
}

const { title, description, href, meta, tags = [] } = Astro.props;
---

<a href={href} class="content-card">
	<Card padding="md" hover={true} class="h-full">
		<div class="content-card__inner">
			{meta && <p class="type-eyebrow">{meta}</p>}
			<h3 class="content-card__title">{title}</h3>
			<p class="content-card__desc line-clamp-3">{description}</p>
			<TagList tags={tags.slice(0, 3)} />
		</div>
	</Card>
</a>

<style>
	.content-card {
		display: block;
		height: 100%;
		text-decoration: none;
	}

	.content-card__inner {
		display: flex;
		height: 100%;
		flex-direction: column;
		gap: var(--space-3);
	}

	.content-card__title {
		font-size: var(--font-size-body-lg);
		font-weight: var(--font-weight-semibold);
		color: var(--color-text);
		transition: var(--transition-hover);
	}

	.content-card:hover .content-card__title {
		color: var(--color-accent);
	}

	.content-card__desc {
		flex: 1;
		font-size: var(--font-size-small);
		color: var(--color-text-secondary);
	}
</style>
