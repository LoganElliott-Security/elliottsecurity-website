---
import { cn } from '../../lib/cn';

interface Props {
	class?: string;
	columns?: 1 | 2 | 3;
}

const { class: className, columns = 3 } = Astro.props;

const columnClasses = {
	1: 'grid-cols-1',
	2: 'grid-cols-1 sm:grid-cols-2',
	3: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
};
---

<div class={cn('grid gap-6', columnClasses[columns], className)}>
	<slot />
</div>
