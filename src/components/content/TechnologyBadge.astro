---
import { getTagUrl } from '../../lib/knowledge';

interface Props {
	technology: string;
}

const { technology } = Astro.props;
---

<a
	href={getTagUrl(technology)}
	class="inline-flex items-center rounded-full border border-border bg-surface-muted px-2.5 py-0.5 text-xs font-medium text-muted no-underline transition-colors hover:border-accent/40 hover:text-accent"
>
	{technology}
</a>
