---
import ContentCard from '../content/ContentCard.astro';
import ContentGrid from '../content/ContentGrid.astro';
import type { ResolvedDetectionRelated } from '../../types/detection';

interface Props {
	related: ResolvedDetectionRelated;
}

const { related } = Astro.props;

const sections = [
	{ title: 'Related Articles', items: related.articles },
	{ title: 'Related Projects', items: related.projects },
	{ title: 'Related Threat Hunts', items: related.threatHunts },
	{ title: 'Related Homelab', items: related.homelab },
	{ title: 'Related Detections', items: related.detections },
].filter((section) => section.items.length > 0);
---

{
	sections.length > 0 && (
		<div class="mt-10 space-y-10 border-t border-border-subtle pt-10">
			{sections.map((section) => (
				<section aria-labelledby={`detection-related-${section.title}`}>
					<h2
						id={`detection-related-${section.title}`}
						class="mb-6 text-xl font-semibold text-foreground"
					>
						{section.title}
					</h2>
					<ContentGrid columns={section.items.length === 1 ? 1 : 3}>
						{section.items.map((item) => (
							<ContentCard
								title={item.title}
								description={item.description}
								href={item.href}
							/>
						))}
					</ContentGrid>
				</section>
			))}
		</div>
	)
}
