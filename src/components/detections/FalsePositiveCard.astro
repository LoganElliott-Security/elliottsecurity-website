---
import type { FalsePositive } from '../../types/detection';
import Card from '../ui/Card.astro';

interface Props {
	item: FalsePositive;
}

const { item } = Astro.props;
---

<Card padding="md">
	<h3 class="text-sm font-semibold text-foreground">False Positive</h3>
	<p class="mt-2 text-sm">{item.description}</p>
	{
		item.mitigation && (
			<div class="mt-4 rounded-md border border-border-subtle bg-surface-muted p-3">
				<p class="text-xs font-medium uppercase tracking-wider text-muted-foreground">Mitigation</p>
				<p class="mt-1 text-sm">{item.mitigation}</p>
			</div>
		)
	}
</Card>
