---
import type { FalsePositive } from '../../types/detection';
import Card from '../ui/Card.astro';

interface Props {
	item: FalsePositive;
}

const { item } = Astro.props;
---

<Card padding="md">
	<h3 class="text-sm font-semibold text-foreground">False Positive</h3>
	<p class="mt-2 text-sm">{item.description}</p>
	{
		item.mitigation && (
			<div class="false-positive__mitigation">
				<p class="false-positive__mitigation-label">Mitigation</p>
				<p class="mt-1 text-sm">{item.mitigation}</p>
			</div>
		)
	}
</Card>

<style>
	.false-positive__mitigation {
		margin-top: var(--space-4);
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border-subtle);
		background-color: var(--color-surface-muted);
		padding: var(--space-3);
	}

	.false-positive__mitigation-label {
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-wide);
		text-transform: uppercase;
		color: var(--color-text-muted);
	}
</style>
