---
import type { DetectionCoverageItem } from '../../types/detection';
import Card from '../ui/Card.astro';

interface Props {
	coverage: DetectionCoverageItem[];
}

const { coverage } = Astro.props;
---

<div class="grid gap-4 sm:grid-cols-2">
	{
		coverage.map((item) => (
			<Card padding="md">
				<div class="flex items-start justify-between gap-4">
					<div>
						<h3 class="text-sm font-semibold text-foreground">{item.category}</h3>
						{item.description && <p class="mt-2 text-sm">{item.description}</p>}
					</div>
					{
						item.percentage !== undefined && (
							<span class="detection-coverage__badge">{item.percentage}%</span>
						)
					}
				</div>
			</Card>
		))
	}
</div>

<style>
	.detection-coverage__badge {
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border);
		background-color: var(--color-surface-muted);
		padding: var(--space-1) var(--space-2);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-medium);
		color: var(--color-accent);
	}
</style>
