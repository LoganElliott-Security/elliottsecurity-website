---
import type { TestingProcedure } from '../../types/detection';
import Card from '../ui/Card.astro';

interface Props {
	procedure: TestingProcedure;
}

const { procedure } = Astro.props;
---

<Card padding="lg">
	{procedure.summary && <p class="text-sm">{procedure.summary}</p>}
	{
		procedure.steps.length > 0 && (
			<ol class="mt-4 list-decimal space-y-2 pl-5 text-sm" role="list">
				{procedure.steps.map((step) => (
					<li>{step}</li>
				))}
			</ol>
		)
	}
	{
		procedure.expectedResults && (
			<div class="testing-procedure__results">
				<p class="testing-procedure__results-label">Expected Results</p>
				<p class="mt-1 text-sm">{procedure.expectedResults}</p>
			</div>
		)
	}
</Card>

<style>
	.testing-procedure__results {
		margin-top: var(--space-6);
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border-subtle);
		background-color: var(--color-surface-muted);
		padding: var(--space-4);
	}

	.testing-procedure__results-label {
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-wide);
		text-transform: uppercase;
		color: var(--color-text-muted);
	}
</style>
