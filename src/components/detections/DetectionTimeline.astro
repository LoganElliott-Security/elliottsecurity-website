---
import type { DetectionRevision } from '../../types/detection';
import Card from '../ui/Card.astro';
import { formatRevisionDate } from '../../lib/detections';
import { formatLabel } from '../../lib/content';

interface Props {
	revisions: DetectionRevision[];
}

const { revisions } = Astro.props;
---

<ol class="detection-timeline" role="list">
	{
		revisions.map((revision) => (
			<li class="detection-timeline__item">
				<span class="detection-timeline__marker" aria-hidden="true" />
				<Card padding="md">
					<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
						<div>
							<p class="text-sm font-semibold text-foreground">Version {revision.version}</p>
							<p class="text-sm text-muted-foreground">{formatRevisionDate(revision.date)}</p>
							{revision.summary && <p class="mt-2 text-sm">{revision.summary}</p>}
						</div>
						<div class="flex flex-wrap items-center gap-2">
							<span class="detection-timeline__status">
								{formatLabel(revision.status)}
							</span>
							{
								revision.downloadPath && (
									<a
										href={revision.downloadPath}
										download={revision.fileName}
										class="detection-timeline__link"
									>
										Download
									</a>
								)
							}
						</div>
					</div>
				</Card>
			</li>
		))
	}
</ol>

<style>
	.detection-timeline {
		position: relative;
		margin: 0;
		padding: 0;
		padding-left: var(--space-6);
		list-style: none;
		border-left: 1px solid var(--color-border);
	}

	.detection-timeline > li + li {
		margin-top: var(--space-6);
	}

	.detection-timeline__item {
		position: relative;
	}

	.detection-timeline__marker {
		position: absolute;
		left: -0.45rem;
		top: 0.375rem;
		height: 0.75rem;
		width: 0.75rem;
		border-radius: var(--radius-pill);
		border: 2px solid var(--color-accent);
		background-color: var(--color-bg);
	}

	.detection-timeline__status {
		border-radius: var(--radius-pill);
		border: 1px solid var(--color-border);
		background-color: var(--color-surface-muted);
		padding: 0.125rem 0.625rem;
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		color: var(--color-text-secondary);
	}

	.detection-timeline__link {
		font-size: var(--font-size-small);
		color: var(--color-accent);
		text-decoration: none;
		transition: var(--transition-hover);
	}

	.detection-timeline__link:hover {
		color: var(--color-soft);
	}
</style>
