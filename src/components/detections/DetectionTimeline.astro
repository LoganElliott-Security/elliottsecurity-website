---
import type { DetectionRevision } from '../../types/detection';
import Card from '../ui/Card.astro';
import { formatRevisionDate } from '../../lib/detections';
import { formatLabel } from '../../lib/content';

interface Props {
	revisions: DetectionRevision[];
}

const { revisions } = Astro.props;
---

<ol class="relative space-y-6 border-l border-border pl-6" role="list">
	{
		revisions.map((revision) => (
			<li class="relative">
				<span
					class="absolute -left-[0.45rem] top-1.5 h-3 w-3 rounded-full border-2 border-accent bg-background"
					aria-hidden="true"
				></span>
				<Card padding="md">
					<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
						<div>
							<p class="text-sm font-semibold text-foreground">Version {revision.version}</p>
							<p class="text-sm text-muted-foreground">{formatRevisionDate(revision.date)}</p>
							{revision.summary && <p class="mt-2 text-sm">{revision.summary}</p>}
						</div>
						<div class="flex flex-wrap items-center gap-2">
							<span class="rounded-full border border-border bg-surface-muted px-2.5 py-0.5 text-xs font-medium text-muted">
								{formatLabel(revision.status)}
							</span>
							{
								revision.downloadPath && (
									<a
										href={revision.downloadPath}
										download={revision.fileName}
										class="text-sm text-accent no-underline hover:text-accent-hover"
									>
										Download
									</a>
								)
							}
						</div>
					</div>
				</Card>
			</li>
		))
	}
</ol>
