---
import { getLanguageLabel } from '../../lib/detections';
import type { DetectionLogicLanguage } from '../../types/detection';

interface Props {
	language: DetectionLogicLanguage | string;
	title?: string;
	code: string;
	fileName?: string;
	downloadPath?: string;
}

const { language, title, code, fileName, downloadPath } = Astro.props;
const label = getLanguageLabel(String(language));
---

<div class="code-block detection-code-block">
	<div class="code-block__header">
		<div class="code-block__meta">
			<span class="code-block__lang">{label}</span>
			{title && <span class="code-block__title">{title}</span>}
		</div>
		{
			downloadPath && (
				<a href={downloadPath} download={fileName} class="code-block__action">
					Download
				</a>
			)
		}
	</div>
	<pre class="code-block__pre" data-language={language}><code>{code}</code></pre>
</div>

<style>
	.code-block {
		overflow: hidden;
		border-radius: var(--radius-lg);
		border: 1px solid var(--color-border);
		background-color: var(--color-bg-secondary);
		box-shadow: var(--shadow-card);
	}

	.code-block__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-4);
		border-bottom: 1px solid var(--color-border-subtle);
		background-color: var(--color-surface);
		padding: var(--space-2) var(--space-4);
	}

	.code-block__meta {
		display: flex;
		align-items: center;
		gap: var(--space-2);
	}

	.code-block__lang {
		border-radius: var(--radius-sm);
		background-color: var(--color-primary-muted);
		padding: var(--space-1) var(--space-2);
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-wide);
		text-transform: uppercase;
		color: var(--color-soft);
	}

	.code-block__title {
		font-size: var(--font-size-small);
		color: var(--color-text-muted);
	}

	.code-block__action {
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		color: var(--color-accent);
		text-decoration: none;
		transition: var(--transition-hover);
	}

	.code-block__action:hover {
		color: var(--color-soft);
	}

	.code-block__pre {
		overflow-x: auto;
		padding: var(--space-4);
		font-size: var(--font-size-small);
		color: var(--color-text);
		margin: 0;
	}

	.code-block__pre code {
		font-family: var(--font-mono);
		color: var(--color-text);
	}
</style>
