---
import { getLanguageLabel } from '../../lib/detections';
import type { DetectionLogicLanguage } from '../../types/detection';

interface Props {
	language: DetectionLogicLanguage | string;
	title?: string;
	code: string;
	fileName?: string;
	downloadPath?: string;
}

const { language, title, code, fileName, downloadPath } = Astro.props;
const label = getLanguageLabel(String(language));
---

<div class="detection-code-block overflow-hidden rounded-lg border border-border bg-surface">
	<div class="flex items-center justify-between gap-4 border-b border-border-subtle bg-surface-muted px-4 py-2">
		<div class="flex items-center gap-2">
			<span class="rounded-sm bg-surface-elevated px-2 py-0.5 text-xs font-medium uppercase tracking-wider text-accent">
				{label}
			</span>
			{title && <span class="text-sm text-muted">{title}</span>}
		</div>
		{
			downloadPath && (
				<a
					href={downloadPath}
					download={fileName}
					class="text-xs font-medium text-accent no-underline hover:text-accent-hover"
				>
					Download
				</a>
			)
		}
	</div>
	<pre class="overflow-x-auto p-4 text-sm" data-language={language}><code>{code}</code></pre>
</div>
