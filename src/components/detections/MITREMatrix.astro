---
import MitreTechnique from '../content/MitreTechnique.astro';

interface Props {
	techniques: string[];
}

const { techniques } = Astro.props;
---

<div class="mitre-matrix">
	<div class="mitre-matrix__header">
		<span>Technique</span>
		<span>Coverage</span>
	</div>
	<ul role="list">
		{
			techniques.map((technique, index) => (
				<li class:list={['mitre-matrix__row', index > 0 && 'mitre-matrix__row--bordered']}>
					<MitreTechnique technique={technique} />
					<span class="mitre-matrix__badge">Mapped</span>
				</li>
			))
		}
	</ul>
</div>

<style>
	.mitre-matrix {
		overflow: hidden;
		border-radius: var(--radius-lg);
		border: 1px solid var(--color-border);
	}

	.mitre-matrix__header {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: var(--space-4);
		border-bottom: 1px solid var(--color-border-subtle);
		background-color: var(--color-surface-muted);
		padding: var(--space-3) var(--space-4);
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-wide);
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	.mitre-matrix ul {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.mitre-matrix__row {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: center;
		gap: var(--space-4);
		padding: var(--space-3) var(--space-4);
	}

	.mitre-matrix__row--bordered {
		border-top: 1px solid var(--color-border-subtle);
	}

	.mitre-matrix__badge {
		border-radius: var(--radius-pill);
		border: 1px solid var(--color-border);
		background-color: var(--color-surface-elevated);
		padding: 0.125rem var(--space-2);
		font-size: var(--font-size-caption);
		color: var(--color-text-secondary);
	}
</style>
