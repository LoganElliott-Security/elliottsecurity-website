---
import MitreTechnique from '../content/MitreTechnique.astro';

interface Props {
	techniques: string[];
}

const { techniques } = Astro.props;
---

<div class="overflow-hidden rounded-lg border border-border">
	<div class="grid grid-cols-[minmax(0,1fr)_auto] gap-4 border-b border-border-subtle bg-surface-muted px-4 py-3 text-xs font-medium uppercase tracking-wider text-muted-foreground">
		<span>Technique</span>
		<span>Coverage</span>
	</div>
	<ul role="list">
		{
			techniques.map((technique, index) => (
				<li
					class={`grid grid-cols-[minmax(0,1fr)_auto] items-center gap-4 px-4 py-3 ${index > 0 ? 'border-t border-border-subtle' : ''}`}
				>
					<MitreTechnique technique={technique} />
					<span class="rounded-full border border-border bg-surface-elevated px-2 py-0.5 text-xs text-muted">
						Mapped
					</span>
				</li>
			))
		}
	</ul>
</div>
