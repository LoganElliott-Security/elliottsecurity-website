---
import Card from '../ui/Card.astro';
import type { RoadmapMilestone, RoadmapPhase } from '../../types/currentFocus';

interface Props {
	milestones: RoadmapMilestone[];
}

const { milestones } = Astro.props;

const phaseLabels: Record<RoadmapPhase, string> = {
	current: 'Current Milestone',
	next: 'Next Milestone',
	future: 'Future Milestone',
};
---

<ol class="relative space-y-8 border-l border-border pl-6" role="list">
	{
		milestones.map((milestone) => (
			<li class="relative">
				<span
					class="absolute -left-[1.625rem] top-1.5 h-3 w-3 rounded-full border-2 border-accent bg-background"
					aria-hidden="true"
				/>
				<Card padding="md">
					<p class="mb-1 text-xs font-medium uppercase tracking-widest text-accent">
						{phaseLabels[milestone.phase]}
					</p>
					<h3 class="text-lg font-semibold text-foreground">{milestone.title}</h3>
					<p class="mt-3 text-sm leading-relaxed text-muted">{milestone.description}</p>
					{
						milestone.items.length > 0 && (
							<ul class="mt-4 space-y-2" role="list">
								{milestone.items.map((item) => (
									<li class="text-sm text-muted before:mr-2 before:text-accent before:content-['—']">
										{item}
									</li>
								))}
							</ul>
						)
					}
				</Card>
			</li>
		))
	}
</ol>
