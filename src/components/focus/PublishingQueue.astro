---
import Card from '../ui/Card.astro';
import type { PublicationStatus, PublishingItem } from '../../types/currentFocus';
import { cn } from '../../lib/cn';

interface Props {
	items: PublishingItem[];
}

const { items } = Astro.props;

const statusLabels: Record<PublicationStatus, string> = {
	planned: 'Planned',
	'in-progress': 'In Progress',
	draft: 'Draft',
};

const statusClasses: Record<PublicationStatus, string> = {
	planned: 'pub-status pub-status--planned',
	'in-progress': 'pub-status pub-status--progress',
	draft: 'pub-status pub-status--draft',
};
---

<ul class="grid gap-3 sm:grid-cols-2" role="list">
	{
		items.map((item) => (
			<li>
				<Card padding="md" class="h-full">
					<div class="flex items-start justify-between gap-3">
						<h3 class="text-sm font-semibold text-foreground">{item.title}</h3>
						<span class={cn('pub-status-base', statusClasses[item.status])}>
							{statusLabels[item.status]}
						</span>
					</div>
					{item.description && <p class="mt-2 text-sm text-muted">{item.description}</p>}
				</Card>
			</li>
		))
	}
</ul>

<style>
	.pub-status-base {
		flex-shrink: 0;
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
	}

	.pub-status--planned {
		color: var(--color-text-muted);
	}

	.pub-status--progress {
		color: var(--color-accent);
	}

	.pub-status--draft {
		color: var(--color-warning-foreground);
	}
</style>
