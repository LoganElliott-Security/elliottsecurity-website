---
import Card from '../ui/Card.astro';
import type { EngineeringProject, ProjectStatus } from '../../types/currentFocus';
import { cn } from '../../lib/cn';

interface Props {
	project: EngineeringProject;
}

const { project } = Astro.props;

const statusLabels: Record<ProjectStatus, string> = {
	planning: 'Planning',
	'in-progress': 'In Progress',
	testing: 'Testing',
	completed: 'Completed',
};

const statusClasses: Record<ProjectStatus, string> = {
	planning: 'status-badge status-badge--muted',
	'in-progress': 'status-badge status-badge--primary',
	testing: 'status-badge status-badge--warning',
	completed: 'status-badge status-badge--success',
};

const Wrapper = project.href ? 'a' : 'div';
const wrapperProps = project.href
	? { href: project.href, class: 'block h-full no-underline' }
	: { class: 'h-full' };
---

<Wrapper {...wrapperProps}>
	<Card padding="md" hover={Boolean(project.href)} class="flex h-full flex-col gap-4">
		<div class="flex items-start justify-between gap-3">
			<h3 class="text-base font-semibold text-foreground">{project.title}</h3>
			<span class={cn('status-badge-base', statusClasses[project.status])}>
				{statusLabels[project.status]}
			</span>
		</div>
		<p class="project-card__desc">{project.description}</p>
		<div>
			<div class="project-card__progress-meta">
				<span>Progress</span>
				<span>{project.progress}%</span>
			</div>
			<div class="project-card__track">
				<div
					class="project-card__fill"
					style={`width: ${project.progress}%`}
					role="progressbar"
					aria-valuenow={project.progress}
					aria-valuemin={0}
					aria-valuemax={100}
					aria-label={`${project.title} progress`}
				/>
			</div>
		</div>
		{project.href && <p class="project-card__cta">View details →</p>}
	</Card>
</Wrapper>

<style>
	.status-badge-base {
		flex-shrink: 0;
		border-radius: var(--radius-pill);
		border: 1px solid transparent;
		padding: var(--space-1) 0.625rem;
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
	}

	.status-badge--muted {
		border-color: color-mix(in srgb, var(--color-disabled) 40%, transparent);
		background-color: var(--color-surface-muted);
		color: var(--color-text-muted);
	}

	.status-badge--primary {
		border-color: color-mix(in srgb, var(--color-primary) 35%, transparent);
		background-color: var(--color-primary-muted);
		color: var(--color-soft);
	}

	.status-badge--warning {
		border-color: color-mix(in srgb, var(--color-warning) 35%, transparent);
		background-color: var(--color-warning-muted);
		color: var(--color-warning-foreground);
	}

	.status-badge--success {
		border-color: color-mix(in srgb, var(--color-success) 35%, transparent);
		background-color: var(--color-success-muted);
		color: var(--color-success-foreground);
	}

	.project-card__desc {
		flex: 1;
		font-size: var(--font-size-small);
		line-height: var(--line-height-relaxed);
		color: var(--color-text-secondary);
	}

	.project-card__progress-meta {
		margin-bottom: var(--space-1);
		display: flex;
		align-items: center;
		justify-content: space-between;
		font-size: var(--font-size-caption);
		color: var(--color-text-muted);
	}

	.project-card__track {
		height: 0.5rem;
		overflow: hidden;
		border-radius: var(--radius-pill);
		background-color: var(--color-surface-muted);
	}

	.project-card__fill {
		height: 100%;
		border-radius: var(--radius-pill);
		background-image: var(--gradient-primary);
		transition: width var(--duration-slow) var(--ease-out);
	}

	.project-card__cta {
		font-size: var(--font-size-small);
		color: var(--color-accent);
	}
</style>
