---
import Card from '../ui/Card.astro';
import type { EngineeringProject, ProjectStatus } from '../../types/currentFocus';
import { cn } from '../../lib/cn';

interface Props {
	project: EngineeringProject;
}

const { project } = Astro.props;
const isCompleted = project.status === 'completed';

const statusLabels: Record<ProjectStatus, string> = {
	planning: 'Planning',
	'in-progress': 'In Progress',
	testing: 'Testing',
	completed: 'Completed',
};

const statusClasses: Record<ProjectStatus, string> = {
	planning: 'status-badge status-badge--muted',
	'in-progress': 'status-badge status-badge--primary',
	testing: 'status-badge status-badge--warning',
	completed: 'status-badge status-badge--success',
};

const Wrapper = project.href ? 'a' : 'div';
const wrapperProps = project.href
	? { href: project.href, class: 'block h-full no-underline' }
	: { class: 'h-full' };
---

<Wrapper {...wrapperProps}>
	<Card
		padding="md"
		hover={Boolean(project.href)}
		class={cn('flex h-full flex-col gap-4', isCompleted && 'project-card--completed')}
	>
		<div class="flex items-start justify-between gap-3">
			<h3 class="text-base font-semibold text-foreground">{project.title}</h3>
			<span class={cn('status-badge-base', statusClasses[project.status])}>
				{isCompleted && (
					<svg class="status-badge__check" viewBox="0 0 16 16" fill="none" aria-hidden="true">
						<path
							d="M3.5 8.5 6.5 11.5 12.5 4.5"
							stroke="currentColor"
							stroke-width="1.75"
							stroke-linecap="round"
							stroke-linejoin="round"
						></path>
					</svg>
				)}
				{statusLabels[project.status]}
			</span>
		</div>
		<p class="project-card__desc">{project.description}</p>
		<div>
			<div class="project-card__progress-meta">
				<span>Progress</span>
				<span>{project.progress}%</span>
			</div>
			<div class="project-card__track">
				<div
					class={cn('project-card__fill', isCompleted && 'project-card__fill--success')}
					style={`--progress: ${project.progress}%`}
					role="progressbar"
					aria-valuenow={project.progress}
					aria-valuemin={0}
					aria-valuemax={100}
					aria-label={`${project.title} progress`}
				/>
			</div>
		</div>
		{project.href && <p class="project-card__cta">View details →</p>}
	</Card>
</Wrapper>

<style>
	.status-badge-base {
		display: inline-flex;
		align-items: center;
		gap: var(--space-1);
		flex-shrink: 0;
		border-radius: var(--radius-pill);
		border: 1px solid transparent;
		padding: var(--space-1) 0.625rem;
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
	}

	.status-badge__check {
		width: 0.75rem;
		height: 0.75rem;
	}

	/* planning = gray */
	.status-badge--muted {
		border-color: color-mix(in srgb, var(--color-disabled) 40%, transparent);
		background-color: var(--color-surface-muted);
		color: var(--color-text-muted);
	}

	/* in-progress = purple brand */
	.status-badge--primary {
		border-color: color-mix(in srgb, var(--color-primary) 35%, transparent);
		background-color: var(--color-primary-muted);
		color: var(--color-soft);
	}

	.status-badge--warning {
		border-color: color-mix(in srgb, var(--color-warning) 35%, transparent);
		background-color: var(--color-warning-muted);
		color: var(--color-warning-foreground);
	}

	/* completed = green */
	.status-badge--success {
		border-color: color-mix(in srgb, var(--color-success) 35%, transparent);
		background-color: var(--color-success-muted);
		color: var(--color-success-foreground);
	}

	.project-card--completed {
		box-shadow: var(--shadow-soft), 0 0 0 1px color-mix(in srgb, var(--color-success) 18%, transparent);
	}

	.project-card__desc {
		flex: 1;
		font-size: var(--font-size-small);
		line-height: var(--line-height-relaxed);
		color: var(--color-text-secondary);
	}

	.project-card__progress-meta {
		margin-bottom: var(--space-1);
		display: flex;
		align-items: center;
		justify-content: space-between;
		font-size: var(--font-size-caption);
		color: var(--color-text-muted);
	}

	.project-card__track {
		height: 0.5rem;
		overflow: hidden;
		border-radius: var(--radius-pill);
		background-color: var(--color-surface-muted);
	}

	.project-card__fill {
		height: 100%;
		width: 0;
		border-radius: var(--radius-pill);
		background-image: var(--gradient-primary);
		animation: project-progress-fill var(--duration-slower) var(--ease-out) forwards;
	}

	.project-card__fill--success {
		background-image: none;
		background-color: var(--color-success);
	}

	@keyframes project-progress-fill {
		to {
			width: var(--progress);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.project-card__fill {
			animation: none;
			width: var(--progress);
			transition: none;
		}
	}

	.project-card__cta {
		font-size: var(--font-size-small);
		color: var(--color-accent);
	}
</style>
