---
import Card from '../ui/Card.astro';
import type { ExperienceEntry } from '../../types/profile';

interface Props {
	entries: ExperienceEntry[];
}

const { entries } = Astro.props;
---

<ol class="experience-timeline" role="list">
	{
		entries.map((entry) => (
			<li class="experience-timeline__item">
				<span class="experience-timeline__marker" aria-hidden="true" />
				<Card padding="md">
					<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
						<div>
							{
								entry.kind === 'education' ? (
									<p class="experience-timeline__label">Education</p>
								) : null
							}
							<h3 class="text-lg font-semibold text-foreground">{entry.role}</h3>
							<p class="experience-timeline__org">{entry.organization}</p>
						</div>
						{entry.period && <p class="shrink-0 text-sm text-muted-foreground">{entry.period}</p>}
					</div>
					<p class="mt-4 text-sm leading-relaxed">{entry.description}</p>
					{
						entry.highlights && entry.highlights.length > 0 && (
							<ul class="experience-timeline__highlights" role="list">
								{entry.highlights.map((highlight) => (
									<li class="experience-timeline__highlight">{highlight}</li>
								))}
							</ul>
						)
					}
				</Card>
			</li>
		))
	}
</ol>

<style>
	.experience-timeline {
		position: relative;
		margin: 0;
		padding: 0;
		padding-left: var(--space-6);
		list-style: none;
		border-left: 1px solid var(--color-border);
	}

	.experience-timeline > li + li {
		margin-top: var(--space-8);
	}

	.experience-timeline__item {
		position: relative;
	}

	.experience-timeline__marker {
		position: absolute;
		left: calc(-1 * var(--space-6) - 0.375rem);
		top: 0.375rem;
		height: 0.75rem;
		width: 0.75rem;
		border-radius: var(--radius-pill);
		border: 2px solid var(--color-accent);
		background-color: var(--color-bg);
	}

	.experience-timeline__label {
		margin-bottom: var(--space-1);
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-widest);
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.experience-timeline__org {
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-medium);
		color: var(--color-accent);
	}

	.experience-timeline__highlights {
		margin-top: var(--space-4);
		padding: 0;
		list-style: none;
	}

	.experience-timeline__highlights > li + li {
		margin-top: var(--space-2);
	}

	.experience-timeline__highlight {
		font-size: var(--font-size-small);
		color: var(--color-text-secondary);
	}

	.experience-timeline__highlight::before {
		margin-right: var(--space-2);
		color: var(--color-accent);
		content: '—';
	}
</style>
