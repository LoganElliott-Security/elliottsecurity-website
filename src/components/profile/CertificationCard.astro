---
import Card from '../ui/Card.astro';
import type { Certification, CertificationStatus } from '../../types/profile';

interface Props {
	certification: Certification;
}

const { certification } = Astro.props;

const statusLabels: Record<CertificationStatus, string> = {
	earned: 'Earned',
	'in-progress': 'In Progress',
	planned: 'Planned',
};

const statusClasses: Record<CertificationStatus, string> = {
	earned: 'cert-status cert-status--earned',
	'in-progress': 'cert-status cert-status--progress',
	planned: 'cert-status cert-status--planned',
};
---

<Card padding="md" class="h-full">
	<div class="flex h-full flex-col gap-4">
		<div class="flex items-start justify-between gap-3">
			<h3 class="text-base font-semibold text-foreground">{certification.name}</h3>
			<span class:list={['cert-status-base', statusClasses[certification.status]]}>
				{statusLabels[certification.status]}
			</span>
		</div>
		{
			certification.issueDate && (
				<p class="text-sm text-muted-foreground">Issued {certification.issueDate}</p>
			)
		}
		{
			certification.credentialUrl ? (
				<a
					href={certification.credentialUrl}
					class="cert-link mt-auto"
					target="_blank"
					rel="noopener noreferrer"
				>
					View credential
				</a>
			) : certification.status === 'earned' ? (
				<p class="mt-auto text-sm text-muted-foreground">CompTIA certified</p>
			) : (
				<p class="mt-auto text-sm text-muted-foreground">In progress</p>
			)
		}
	</div>
</Card>

<style>
	.cert-status-base {
		flex-shrink: 0;
		border-radius: var(--radius-pill);
		border: 1px solid transparent;
		padding: var(--space-1) 0.625rem;
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
	}

	.cert-status--earned {
		border-color: color-mix(in srgb, var(--color-primary) 35%, transparent);
		background-color: var(--color-primary-muted);
		color: var(--color-soft);
	}

	.cert-status--progress {
		border-color: color-mix(in srgb, var(--color-warning) 35%, transparent);
		background-color: var(--color-warning-muted);
		color: var(--color-warning-foreground);
	}

	.cert-status--planned {
		border-color: var(--color-border);
		background-color: var(--color-surface-muted);
		color: var(--color-text-muted);
	}

	.cert-link {
		font-size: var(--font-size-small);
		color: var(--color-accent);
		text-decoration: none;
		transition: var(--transition-hover);
	}

	.cert-link:hover {
		color: var(--color-soft);
		text-decoration: underline;
	}
</style>
