---
import Card from '../ui/Card.astro';
import type { Technology } from '../../types/profile';

interface Props {
	technologies: Technology[];
}

const { technologies } = Astro.props;

const categoryLabels: Record<Technology['category'], string> = {
	security: 'Security',
	platform: 'Platform',
	development: 'Development',
	infrastructure: 'Infrastructure',
	forensics: 'Forensics',
	skills: 'Skills',
};
---

<ul class="grid gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4" role="list">
	{
		technologies.map((tech) => (
			<li>
				<Card padding="md" class="h-full text-center">
					<div class="tech-grid__icon" aria-hidden="true">
						{tech.name.slice(0, 2).toUpperCase()}
					</div>
					<h3 class="text-sm font-semibold text-foreground">{tech.name}</h3>
					<p class="mt-1 text-xs text-muted-foreground">{categoryLabels[tech.category]}</p>
				</Card>
			</li>
		))
	}
</ul>

<style>
	.tech-grid__icon {
		margin-inline: auto;
		margin-bottom: var(--space-3);
		display: flex;
		height: 3rem;
		width: 3rem;
		align-items: center;
		justify-content: center;
		border-radius: var(--radius-lg);
		border: 1px solid var(--color-border);
		background-color: var(--color-surface-muted);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-bold);
		color: var(--color-accent);
	}
</style>
