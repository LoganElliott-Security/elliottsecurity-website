---
import Card from '../ui/Card.astro';

interface Props {
	items: string[];
	columns?: 2 | 3 | 4;
}

const { items, columns = 3 } = Astro.props;

const columnClasses = {
	2: 'sm:grid-cols-2',
	3: 'sm:grid-cols-2 lg:grid-cols-3',
	4: 'sm:grid-cols-2 lg:grid-cols-4',
};
---

<ul class:list={['grid gap-3', columnClasses[columns]]} role="list">
	{
		items.map((item) => (
			<li>
				<Card padding="md" class="h-full">
					<p class="text-sm font-medium text-foreground">{item}</p>
				</Card>
			</li>
		))
	}
</ul>
