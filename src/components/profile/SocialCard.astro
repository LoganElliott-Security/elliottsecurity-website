---
import Card from '../ui/Card.astro';
import type { SocialProfile } from '../../types/profile';

interface Props {
	profile: SocialProfile;
	size?: 'default' | 'large';
}

const { profile, size = 'default' } = Astro.props;

const isExternal = profile.href.startsWith('http') || profile.href.startsWith('mailto:');
const isResume = profile.id === 'resume';
const isLarge = size === 'large';
const actionLabel = isResume ? 'Download resume →' : profile.id === 'email' ? 'Send email →' : 'Visit profile →';
---

<a
	href={profile.href}
	class="social-card group block h-full no-underline"
	target={isExternal ? '_blank' : undefined}
	rel={isExternal ? 'noopener noreferrer' : undefined}
	download={isResume ? true : undefined}
>
	<Card
		padding={isLarge ? 'lg' : 'md'}
		hover={true}
		class="social-card__inner h-full"
	>
		<div class="flex h-full flex-col gap-3">
			<div class="flex items-center gap-3">
				<span
					class:list={['social-card__icon', isLarge && 'social-card__icon--large']}
					aria-hidden="true"
				>
					{profile.label.slice(0, 1)}
				</span>
				<h3 class:list={['font-semibold text-foreground', isLarge ? 'text-xl' : 'text-base']}>
					{profile.label}
				</h3>
			</div>
			{
				profile.description && (
					<p class:list={['leading-relaxed text-muted', isLarge ? 'text-base' : 'text-sm']}>
						{profile.description}
					</p>
				)
			}
			<p class="social-card__action mt-auto text-sm">{actionLabel}</p>
		</div>
	</Card>
</a>

<style>
	.social-card__inner {
		transition: border-color var(--duration-normal) var(--ease-default);
	}

	.social-card:hover .social-card__inner {
		border-color: color-mix(in srgb, var(--color-accent) 40%, var(--color-border));
	}

	.social-card__icon {
		display: flex;
		align-items: center;
		justify-content: center;
		height: 2.5rem;
		width: 2.5rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border);
		background-color: var(--color-surface-muted);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-semibold);
		color: var(--color-accent);
	}

	.social-card__icon--large {
		height: 3rem;
		width: 3rem;
		font-size: var(--font-size-body);
	}

	.social-card__action {
		color: var(--color-accent);
		transition: var(--transition-hover);
	}

	.social-card:hover .social-card__action {
		color: var(--color-soft);
	}
</style>
