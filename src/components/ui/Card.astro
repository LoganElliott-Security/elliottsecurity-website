---
import { cn } from '../../lib/cn';

interface Props {
	class?: string;
	padding?: 'none' | 'sm' | 'md' | 'lg';
	hover?: boolean;
}

const { class: className, padding = 'md', hover = false } = Astro.props;

const paddingClasses = {
	none: '',
	sm: 'p-4',
	md: 'p-6',
	lg: 'p-8',
};
---

<div
	class={cn(
		'rounded-lg border border-border bg-surface-elevated shadow-sm',
		paddingClasses[padding],
		hover && 'transition-colors duration-200 hover:border-accent/40 hover:bg-surface-muted',
		className,
	)}
>
	<slot />
</div>
