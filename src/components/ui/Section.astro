---
import { cn } from '../../lib/cn';
import Container from './Container.astro';

interface Props {
	id?: string;
	class?: string;
	containerClass?: string;
	background?: 'default' | 'muted' | 'elevated';
	padding?: boolean;
}

const {
	id,
	class: className,
	containerClass,
	background = 'default',
	padding = true,
} = Astro.props;

const backgroundClasses = {
	default: 'bg-background',
	muted: 'bg-surface',
	elevated: 'bg-surface-elevated',
};
---

<section
	id={id}
	class={cn(backgroundClasses[background], padding && 'section-padding', className)}
>
	<Container class={containerClass}>
		<slot />
	</Container>
</section>
