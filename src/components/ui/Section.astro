---
import { cn } from '../../lib/cn';
import Container from './Container.astro';

interface Props {
	id?: string;
	class?: string;
	containerClass?: string;
	background?: 'default' | 'muted' | 'elevated' | 'secondary';
	padding?: boolean;
}

const {
	id,
	class: className,
	containerClass,
	background = 'default',
	padding = true,
} = Astro.props;

const backgroundClasses = {
	default: 'section-bg-default',
	muted: 'section-bg-muted',
	elevated: 'section-bg-elevated',
	secondary: 'section-bg-secondary',
};
---

<section
	id={id}
	class={cn('es-section', backgroundClasses[background], padding && 'section-padding', className)}
>
	<Container class={containerClass}>
		<slot />
	</Container>
</section>

<style>
	.section-bg-default {
		background-color: transparent;
	}

	.section-bg-muted {
		background-color: var(--color-bg-secondary);
	}

	.section-bg-elevated {
		background-color: var(--color-surface);
	}

	.section-bg-secondary {
		background-color: var(--color-bg-secondary);
	}
</style>
