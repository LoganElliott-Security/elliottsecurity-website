---
import { cn } from '../../lib/cn';

interface Props {
	src: string;
	alt: string;
	class?: string;
}

const { src, alt, class: className } = Astro.props;
const resolvedSrc = src?.trim() ?? '';
---

{
	resolvedSrc && (
		<figure class={cn('cover-image', className)} data-cover-image>
			<img
				src={resolvedSrc}
				alt={alt}
				loading="lazy"
				decoding="async"
				class="cover-image__img"
				onerror="const mark=this.closest('[data-cover-image]'); const wrap=mark?.parentElement; mark?.remove(); if (wrap?.classList?.contains('content-hero__cover') && !wrap.querySelector('[data-cover-image]')) wrap.remove();"
			/>
		</figure>
	)
}

<style>
	.cover-image {
		margin: 0;
		overflow: hidden;
		border-radius: var(--radius-lg);
		border: 1px solid var(--color-border);
		background-color: transparent;
		line-height: 0;
	}

	.cover-image__img {
		display: block;
		width: 100%;
		height: auto;
		max-width: 100%;
	}
</style>
