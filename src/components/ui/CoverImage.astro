---
import { cn } from '../../lib/cn';

interface Props {
	src: string;
	alt: string;
	class?: string;
}

const { src, alt, class: className } = Astro.props;
---

<div class="cover-image-wrapper overflow-hidden rounded-lg border border-border bg-surface-muted">
	<img
		src={src}
		alt={alt}
		loading="lazy"
		decoding="async"
		class={cn('h-auto w-full object-cover', className)}
		onerror="this.classList.add('hidden'); this.nextElementSibling?.classList.remove('hidden')"
	/>
	<p class="hidden p-4 text-sm text-muted-foreground" role="status">
		Cover image unavailable.
	</p>
</div>
