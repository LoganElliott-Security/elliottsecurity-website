---
import { cn } from '../../lib/cn';

interface Props {
	class?: string;
	size?: 'default' | 'narrow' | 'wide';
}

const { class: className, size = 'default' } = Astro.props;

const sizeClasses = {
	default: 'max-w-7xl',
	narrow: 'max-w-3xl',
	wide: 'max-w-[90rem]',
};
---

<div class={cn('mx-auto w-full px-4 sm:px-6 lg:px-8', sizeClasses[size], className)}>
	<slot />
</div>
