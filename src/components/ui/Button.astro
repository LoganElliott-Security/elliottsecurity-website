---
import { cn } from '../../lib/cn';

type ButtonVariant = 'primary' | 'secondary' | 'ghost' | 'outline';
type ButtonSize = 'sm' | 'md' | 'lg';

interface Props {
	href?: string;
	variant?: ButtonVariant;
	size?: ButtonSize;
	class?: string;
	type?: 'button' | 'submit' | 'reset';
	disabled?: boolean;
	download?: boolean | string;
}

const {
	href,
	variant = 'primary',
	size = 'md',
	class: className,
	type = 'button',
	disabled = false,
	download,
} = Astro.props;

const baseClasses =
	'btn inline-flex items-center justify-center gap-2 font-medium focus-visible:outline-none disabled:pointer-events-none';

const variantClasses: Record<ButtonVariant, string> = {
	primary: 'btn-primary',
	secondary: 'btn-secondary',
	ghost: 'btn-ghost',
	outline: 'btn-outline',
};

const sizeClasses: Record<ButtonSize, string> = {
	sm: 'btn-sm',
	md: 'btn-md',
	lg: 'btn-lg',
};

const classes = cn(baseClasses, variantClasses[variant], sizeClasses[size], className);
---

{
	href ? (
		<a href={href} class={classes} download={download}>
			<slot />
		</a>
	) : (
		<button type={type} class={classes} disabled={disabled}>
			<slot />
		</button>
	)
}

<style>
	.btn {
		border-radius: var(--radius-md);
		transition: var(--transition-hover);
	}

	.btn:disabled,
	.btn[aria-disabled='true'] {
		opacity: var(--opacity-disabled);
	}

	.btn:focus-visible {
		outline: 2px solid var(--color-ring);
		outline-offset: 2px;
	}

	.btn-primary {
		color: var(--color-primary-foreground);
		background-image: var(--gradient-primary);
		box-shadow: var(--shadow-soft), var(--glow-soft);
		border: 1px solid color-mix(in srgb, var(--color-primary) 50%, transparent);
	}

	.btn-primary:hover {
		background-image: var(--gradient-primary-hover);
		box-shadow: var(--shadow-glow);
		transform: translateY(-1px);
	}

	.btn-secondary {
		color: var(--color-text);
		background-color: var(--color-surface-elevated);
		border: 1px solid var(--color-border);
		box-shadow: var(--shadow-soft);
	}

	.btn-secondary:hover {
		background-color: var(--color-surface);
		border-color: color-mix(in srgb, var(--color-primary) 35%, var(--color-border));
	}

	.btn-ghost {
		color: var(--color-text-muted);
		background-color: transparent;
		border: 1px solid transparent;
	}

	.btn-ghost:hover {
		color: var(--color-text);
		background-color: var(--color-surface-elevated);
	}

	.btn-outline {
		color: var(--color-text);
		background-color: transparent;
		border: 1px solid var(--color-border);
	}

	.btn-outline:hover {
		color: var(--color-accent);
		border-color: color-mix(in srgb, var(--color-primary) 50%, var(--color-border));
		background-color: var(--color-primary-muted);
	}

	.btn-sm {
		height: 2.25rem;
		padding-inline: var(--space-3);
		font-size: var(--font-size-small);
	}

	.btn-md {
		height: 2.75rem;
		padding-inline: var(--space-5);
		font-size: var(--font-size-small);
	}

	.btn-lg {
		height: 3rem;
		padding-inline: var(--space-6);
		font-size: var(--font-size-body);
	}
</style>
