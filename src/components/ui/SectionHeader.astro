---
import Button from './Button.astro';
import { cn } from '../../lib/cn';

interface Props {
	title: string;
	description?: string;
	eyebrow?: string;
	actionLabel?: string;
	actionHref?: string;
	align?: 'left' | 'center';
	class?: string;
}

const {
	title,
	description,
	eyebrow,
	actionLabel,
	actionHref,
	align = 'left',
	class: className,
} = Astro.props;

const alignClasses = {
	left: 'section-header--left',
	center: 'section-header--center',
};
---

<header class={cn('section-header', alignClasses[align], className)}>
	{eyebrow && <p class="type-eyebrow">{eyebrow}</p>}
	<h2 class="type-h2 text-balance">{title}</h2>
	{description && <p class="section-header__desc text-balance">{description}</p>}
	{
		actionLabel && actionHref && (
			<div class="section-header__action">
				<Button href={actionHref} variant="ghost" size="sm">
					{actionLabel}
				</Button>
			</div>
		)
	}
</header>

<style>
	.section-header {
		display: flex;
		max-width: 48rem;
		flex-direction: column;
		gap: var(--space-3);
		margin-bottom: var(--space-10);
	}

	@media (min-width: 640px) {
		.section-header {
			margin-bottom: var(--space-12);
		}
	}

	.section-header--left {
		align-items: flex-start;
		text-align: left;
	}

	.section-header--center {
		align-items: center;
		margin-inline: auto;
		text-align: center;
	}

	.section-header__desc {
		font-size: var(--font-size-body);
		color: var(--color-text-secondary);
	}

	@media (min-width: 640px) {
		.section-header__desc {
			font-size: var(--font-size-body-lg);
		}
	}

	.section-header__action {
		margin-top: var(--space-2);
	}
</style>
