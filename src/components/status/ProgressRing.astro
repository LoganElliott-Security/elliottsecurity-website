---
interface Props {
	value: number;
	label?: string;
}

const { value, label = 'Overall' } = Astro.props;
const clamped = Math.max(0, Math.min(100, value));
const radius = 54;
const circumference = 2 * Math.PI * radius;
const offset = circumference - (clamped / 100) * circumference;
---

<div class="progress-ring" role="img" aria-label={`${label} progress ${clamped} percent`}>
	<svg class="progress-ring__svg" viewBox="0 0 120 120" aria-hidden="true">
		<circle class="progress-ring__track" cx="60" cy="60" r={radius}></circle>
		<circle
			class="progress-ring__value"
			cx="60"
			cy="60"
			r={radius}
			stroke-dasharray={circumference}
			stroke-dashoffset={offset}
		></circle>
	</svg>
	<div class="progress-ring__label">
		<span class="progress-ring__percent">{clamped}%</span>
		<span class="progress-ring__caption">{label}</span>
	</div>
</div>

<style>
	.progress-ring {
		position: relative;
		display: grid;
		place-items: center;
		width: 8.5rem;
		height: 8.5rem;
	}

	.progress-ring__svg {
		width: 100%;
		height: 100%;
		transform: rotate(-90deg);
	}

	.progress-ring__track,
	.progress-ring__value {
		fill: none;
		stroke-width: 8;
	}

	.progress-ring__track {
		stroke: var(--color-border);
	}

	.progress-ring__value {
		stroke: var(--color-accent);
		stroke-linecap: round;
		transition: stroke-dashoffset 700ms var(--ease-out);
	}

	.progress-ring__label {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.15rem;
		text-align: center;
	}

	.progress-ring__percent {
		font-size: var(--font-size-h3);
		font-weight: var(--font-weight-semibold);
		color: var(--color-text);
		line-height: 1;
	}

	.progress-ring__caption {
		font-size: var(--font-size-caption);
		letter-spacing: var(--letter-spacing-wide);
		text-transform: uppercase;
		color: var(--color-text-muted);
	}
</style>
