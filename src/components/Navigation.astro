---
import { MAIN_NAV, isNavItemActive } from '../config/navigation';
import { SITE } from '../config/site';
import { cn } from '../lib/cn';
import Container from './ui/Container.astro';

const currentPath = Astro.url.pathname;
---

<header class="es-nav">
	<Container>
		<nav class="es-nav__bar" aria-label="Main navigation">
			<a
				href="/"
				class="es-nav__brand"
				aria-label={`${SITE.name} home`}
			>
				<span class="es-nav__mark" aria-hidden="true">
					<svg class="es-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"
						></path>
					</svg>
				</span>
				<span class="es-nav__name">{SITE.name}</span>
			</a>

			<ul class="es-nav__links" role="list">
				{
					MAIN_NAV.map((item) => (
						<li>
							<a
								href={item.href}
								class={cn(
									'es-nav__link',
									isNavItemActive(item.href, currentPath) && 'es-nav__link--active',
								)}
								aria-current={isNavItemActive(item.href, currentPath) ? 'page' : undefined}
							>
								{item.label}
							</a>
						</li>
					))
				}
			</ul>

			<button
				type="button"
				class="es-nav__toggle"
				aria-expanded="false"
				aria-controls="mobile-nav"
				aria-label="Open menu"
				data-nav-toggle
			>
				<svg
					class="es-nav__toggle-icon"
					data-icon-open
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
					stroke-width="1.5"
					aria-hidden="true"
				>
					<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5M3.75 15h16.5"></path>
				</svg>
				<svg
					class="es-nav__toggle-icon es-nav__toggle-icon--hidden"
					data-icon-close
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
					stroke-width="1.5"
					aria-hidden="true"
				>
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
				</svg>
			</button>
		</nav>
	</Container>

	<div id="mobile-nav" class="es-nav__mobile es-nav__mobile--hidden" data-mobile-nav>
		<Container>
			<ul class="es-nav__mobile-list" role="list">
				{
					MAIN_NAV.map((item) => (
						<li>
							<a
								href={item.href}
								class={cn(
									'es-nav__mobile-link',
									isNavItemActive(item.href, currentPath) && 'es-nav__link--active',
								)}
								aria-current={isNavItemActive(item.href, currentPath) ? 'page' : undefined}
							>
								{item.label}
							</a>
						</li>
					))
				}
			</ul>
		</Container>
	</div>
</header>

<style>
	.es-nav {
		position: sticky;
		top: 0;
		z-index: var(--z-nav);
		border-bottom: 1px solid color-mix(in srgb, var(--color-border) 60%, transparent);
		background-color: color-mix(in srgb, var(--color-bg) calc(var(--opacity-glass) * 100%), transparent);
		backdrop-filter: blur(var(--blur-nav));
		-webkit-backdrop-filter: blur(var(--blur-nav));
		box-shadow: var(--shadow-soft);
	}

	.es-nav__bar {
		display: flex;
		height: 4rem;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-4);
	}

	.es-nav__brand {
		display: flex;
		flex-shrink: 0;
		align-items: center;
		gap: 0.625rem;
		color: var(--color-text);
		text-decoration: none;
	}

	.es-nav__mark {
		display: flex;
		height: 2rem;
		width: 2rem;
		align-items: center;
		justify-content: center;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border);
		background-color: var(--color-surface-elevated);
		color: var(--color-primary);
		transition: var(--transition-hover);
	}

	.es-nav__brand:hover .es-nav__mark {
		border-color: color-mix(in srgb, var(--color-primary) 50%, var(--color-border));
		box-shadow: var(--glow-soft);
	}

	.es-nav__icon {
		height: 1rem;
		width: 1rem;
	}

	.es-nav__name {
		display: none;
		font-weight: var(--font-weight-semibold);
		letter-spacing: var(--letter-spacing-tight);
	}

	@media (min-width: 640px) {
		.es-nav__name {
			display: inline;
		}
	}

	.es-nav__links {
		display: none;
		align-items: center;
		gap: 0.125rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	@media (min-width: 1280px) {
		.es-nav__links {
			display: flex;
		}
	}

	.es-nav__link {
		border-radius: var(--radius-md);
		padding: var(--space-2) 0.625rem;
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-medium);
		color: var(--color-text-muted);
		text-decoration: none;
		transition: var(--transition-hover);
	}

	@media (min-width: 1280px) {
		.es-nav__link {
			padding-inline: var(--space-3);
		}
	}

	.es-nav__link:hover {
		background-color: var(--color-surface-elevated);
		color: var(--color-text);
	}

	.es-nav__link--active {
		background-color: var(--color-primary-muted);
		color: var(--color-soft);
		box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-primary) 35%, transparent);
	}

	.es-nav__toggle {
		display: inline-flex;
		height: 2.5rem;
		width: 2.5rem;
		align-items: center;
		justify-content: center;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border);
		background-color: var(--color-surface-elevated);
		color: var(--color-text);
		cursor: pointer;
		transition: var(--transition-hover);
	}

	.es-nav__toggle:hover {
		border-color: color-mix(in srgb, var(--color-primary) 40%, var(--color-border));
	}

	@media (min-width: 1280px) {
		.es-nav__toggle {
			display: none;
		}
	}

	.es-nav__toggle-icon {
		height: 1.25rem;
		width: 1.25rem;
	}

	.es-nav__toggle-icon--hidden {
		display: none;
	}

	.es-nav__mobile {
		border-top: 1px solid var(--color-border-subtle);
	}

	.es-nav__mobile--hidden {
		display: none;
	}

	@media (min-width: 1280px) {
		.es-nav__mobile {
			display: none;
		}
	}

	.es-nav__mobile-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-1);
		padding-block: var(--space-4);
		list-style: none;
		margin: 0;
	}

	.es-nav__mobile-link {
		display: block;
		border-radius: var(--radius-md);
		padding: 0.625rem var(--space-3);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-medium);
		color: var(--color-text-muted);
		text-decoration: none;
		transition: var(--transition-hover);
	}

	.es-nav__mobile-link:hover {
		background-color: var(--color-surface-elevated);
		color: var(--color-text);
	}
</style>

<script>
	const toggle = document.querySelector('[data-nav-toggle]');
	const mobileNav = document.querySelector('[data-mobile-nav]');
	const iconOpen = document.querySelector('[data-icon-open]');
	const iconClose = document.querySelector('[data-icon-close]');

	if (toggle && mobileNav && iconOpen && iconClose) {
		const setOpen = (open: boolean) => {
			mobileNav.classList.toggle('es-nav__mobile--hidden', !open);
			iconOpen.classList.toggle('es-nav__toggle-icon--hidden', open);
			iconClose.classList.toggle('es-nav__toggle-icon--hidden', !open);
			toggle.setAttribute('aria-expanded', String(open));
			toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
		};

		toggle.addEventListener('click', () => {
			const isOpen = !mobileNav.classList.contains('es-nav__mobile--hidden');
			setOpen(!isOpen);
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && !mobileNav.classList.contains('es-nav__mobile--hidden')) {
				setOpen(false);
				(toggle as HTMLButtonElement).focus();
			}
		});

		mobileNav.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', () => {
				setOpen(false);
			});
		});
	}
</script>
