---
import { MAIN_NAV, isNavItemActive } from '../config/navigation';
import { SITE } from '../config/site';
import { cn } from '../lib/cn';
import Container from './ui/Container.astro';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-border-subtle bg-background/90 backdrop-blur-md">
	<Container>
		<nav class="flex h-16 items-center justify-between gap-4" aria-label="Main navigation">
			<a
				href="/"
				class="group flex shrink-0 items-center gap-2.5 text-foreground no-underline"
				aria-label={`${SITE.name} home`}
			>
				<span
					class="flex h-8 w-8 items-center justify-center rounded-md border border-border bg-surface-elevated text-accent transition-colors group-hover:border-accent/50"
					aria-hidden="true"
				>
					<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"
						></path>
					</svg>
				</span>
				<span class="hidden font-semibold tracking-tight sm:inline">{SITE.name}</span>
			</a>

			<ul class="hidden items-center gap-0.5 xl:flex" role="list">
				{
					MAIN_NAV.map((item) => (
						<li>
							<a
								href={item.href}
								class={cn(
									'rounded-md px-2.5 py-2 text-sm font-medium no-underline transition-colors xl:px-3',
									isNavItemActive(item.href, currentPath)
										? 'bg-surface-elevated text-accent'
										: 'text-muted hover:bg-surface-elevated hover:text-foreground',
								)}
								aria-current={isNavItemActive(item.href, currentPath) ? 'page' : undefined}
							>
								{item.label}
							</a>
						</li>
					))
				}
			</ul>

			<button
				type="button"
				class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-border bg-surface-elevated text-foreground xl:hidden"
				aria-expanded="false"
				aria-controls="mobile-nav"
				aria-label="Open menu"
				data-nav-toggle
			>
				<svg
					class="h-5 w-5"
					data-icon-open
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
					stroke-width="1.5"
					aria-hidden="true"
				>
					<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5M3.75 15h16.5"></path>
				</svg>
				<svg
					class="hidden h-5 w-5"
					data-icon-close
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
					stroke-width="1.5"
					aria-hidden="true"
				>
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
				</svg>
			</button>
		</nav>
	</Container>

	<div id="mobile-nav" class="hidden border-t border-border-subtle xl:hidden" data-mobile-nav>
		<Container>
			<ul class="flex flex-col gap-1 py-4" role="list">
				{
					MAIN_NAV.map((item) => (
						<li>
							<a
								href={item.href}
								class={cn(
									'block rounded-md px-3 py-2.5 text-sm font-medium no-underline transition-colors',
									isNavItemActive(item.href, currentPath)
										? 'bg-surface-elevated text-accent'
										: 'text-muted hover:bg-surface-elevated hover:text-foreground',
								)}
								aria-current={isNavItemActive(item.href, currentPath) ? 'page' : undefined}
							>
								{item.label}
							</a>
						</li>
					))
				}
			</ul>
		</Container>
	</div>
</header>

<script>
	const toggle = document.querySelector('[data-nav-toggle]');
	const mobileNav = document.querySelector('[data-mobile-nav]');
	const iconOpen = document.querySelector('[data-icon-open]');
	const iconClose = document.querySelector('[data-icon-close]');

	if (toggle && mobileNav && iconOpen && iconClose) {
		toggle.addEventListener('click', () => {
			const isOpen = !mobileNav.classList.contains('hidden');
			mobileNav.classList.toggle('hidden', isOpen);
			iconOpen.classList.toggle('hidden', !isOpen);
			iconClose.classList.toggle('hidden', isOpen);
			toggle.setAttribute('aria-expanded', String(!isOpen));
			toggle.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && !mobileNav.classList.contains('hidden')) {
				mobileNav.classList.add('hidden');
				iconOpen.classList.remove('hidden');
				iconClose.classList.add('hidden');
				toggle.setAttribute('aria-expanded', 'false');
				toggle.setAttribute('aria-label', 'Open menu');
				(toggle as HTMLButtonElement).focus();
			}
		});

		mobileNav.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', () => {
				mobileNav.classList.add('hidden');
				iconOpen.classList.remove('hidden');
				iconClose.classList.add('hidden');
				toggle.setAttribute('aria-expanded', 'false');
				toggle.setAttribute('aria-label', 'Open menu');
			});
		});
	}
</script>
