---
import { FOOTER_NAV } from '../config/navigation';
import { PROFILE } from '../config/profile';
import { SITE } from '../config/site';
import { getFooterSocialLabel, getSocialProfiles } from '../config/social';
import Container from './ui/Container.astro';

const currentYear = new Date().getFullYear();
const footerSocial = getSocialProfiles({ footer: true });
---

<footer class="border-t border-border-subtle bg-surface">
	<Container>
		<div class="grid gap-10 py-12 sm:grid-cols-2 lg:grid-cols-5 lg:gap-8">
			<div class="sm:col-span-2">
				<a href="/" class="inline-flex items-center gap-2 text-foreground no-underline">
					<span
						class="flex h-8 w-8 items-center justify-center rounded-md border border-border bg-surface-elevated text-accent"
						aria-hidden="true"
					>
						<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"
							></path>
						</svg>
					</span>
					<span class="font-semibold">{PROFILE.name}</span>
				</a>
				{
					PROFILE.titles.map((title) => (
						<p class="mt-3 text-sm font-medium text-foreground">{title}</p>
					))
				}
				<p class="mt-4 max-w-xs text-sm">{SITE.motto}</p>
			</div>

			{
				FOOTER_NAV.map((group) => (
					<div>
						<h2 class="text-sm font-semibold text-foreground">{group.title}</h2>
						<ul class="mt-4 space-y-2" role="list">
							{group.items.map((item) => (
								<li>
									<a href={item.href} class="text-sm text-muted no-underline hover:text-accent">
										{item.label}
									</a>
								</li>
							))}
						</ul>
					</div>
				))
			}
		</div>

		<div class="flex flex-col gap-6 border-t border-border-subtle py-6">
			<ul class="flex flex-wrap gap-4" role="list">
				{
					footerSocial.map((profile) => {
						const isExternal =
							profile.href.startsWith('http') || profile.href.startsWith('mailto:');
						return (
							<li>
								<a
									href={profile.href}
									class="text-sm text-muted no-underline hover:text-accent"
									target={isExternal ? '_blank' : undefined}
									rel={isExternal ? 'noopener noreferrer' : undefined}
									download={profile.id === 'resume' ? true : undefined}
								>
									{getFooterSocialLabel(profile)}
								</a>
							</li>
						);
					})
				}
			</ul>
			<div class="flex flex-col gap-2 text-sm text-muted-foreground sm:flex-row sm:items-center sm:justify-between">
				<p>&copy; {currentYear} {PROFILE.name}. All rights reserved.</p>
				<p>
					Powered by <a href="https://astro.build" class="text-muted hover:text-accent" target="_blank" rel="noopener noreferrer">Astro</a>
					{' · '}
					Hosted on <a href="https://pages.cloudflare.com" class="text-muted hover:text-accent" target="_blank" rel="noopener noreferrer">Cloudflare Pages</a>
				</p>
			</div>
		</div>
	</Container>
</footer>
