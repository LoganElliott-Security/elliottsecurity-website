---
import { FOOTER_NAV } from '../config/navigation';
import { PROFILE } from '../config/profile';
import { SITE } from '../config/site';
import { getFooterSocialLabel, getSocialProfiles } from '../config/social';
import LogoMark from './brand/LogoMark.astro';
import Container from './ui/Container.astro';

const currentYear = new Date().getFullYear();
const footerSocial = getSocialProfiles({ footer: true });
---

<footer class="es-footer">
	<Container>
		<div class="es-footer__grid">
			<div class="es-footer__brand">
				<a href="/" class="es-footer__brand-link">
					<span class="es-footer__mark" aria-hidden="true">
						<LogoMark class="es-footer__icon" />
					</span>
					<span class="es-footer__name">{PROFILE.name}</span>
				</a>
				{
					PROFILE.titles.map((title) => (
						<p class="es-footer__title">{title}</p>
					))
				}
				<p class="es-footer__motto">{SITE.motto}</p>
			</div>

			{
				FOOTER_NAV.map((group) => (
					<div>
						<h2 class="es-footer__heading">{group.title}</h2>
						<ul class="es-footer__list" role="list">
							{group.items.map((item) => (
								<li>
									<a href={item.href} class="es-footer__link link-underline">
										{item.label}
									</a>
								</li>
							))}
						</ul>
					</div>
				))
			}
		</div>

		<div class="es-footer__bottom">
			<ul class="es-footer__social" role="list">
				{
					footerSocial.map((profile) => {
						const isExternal =
							profile.href.startsWith('http') || profile.href.startsWith('mailto:');
						return (
							<li>
								<a
									href={profile.href}
									class="es-footer__link link-underline"
									target={isExternal ? '_blank' : undefined}
									rel={isExternal ? 'noopener noreferrer' : undefined}
									download={profile.id === 'resume' ? true : undefined}
								>
									{getFooterSocialLabel(profile)}
								</a>
							</li>
						);
					})
				}
			</ul>
			<div class="es-footer__meta">
				<p>&copy; {currentYear} {PROFILE.name}. All rights reserved.</p>
				<p>
					Powered by <a href="https://astro.build" class="es-footer__link link-underline" target="_blank" rel="noopener noreferrer">Astro</a>
					{' · '}
					Hosted on <a href="https://pages.cloudflare.com" class="es-footer__link link-underline" target="_blank" rel="noopener noreferrer">Cloudflare Pages</a>
				</p>
			</div>
		</div>
	</Container>
</footer>

<style>
	.es-footer {
		border-top: 1px solid var(--color-border-subtle);
		background-color: var(--color-bg-secondary);
	}

	.es-footer__grid {
		display: grid;
		gap: var(--space-10);
		padding-block: var(--space-12);
	}

	@media (min-width: 640px) {
		.es-footer__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.es-footer__grid {
			grid-template-columns: repeat(5, minmax(0, 1fr));
			gap: var(--space-8);
		}
	}

	.es-footer__brand {
		grid-column: span 1;
	}

	@media (min-width: 640px) {
		.es-footer__brand {
			grid-column: span 2;
		}
	}

	.es-footer__brand-link {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		color: var(--color-text);
		text-decoration: none;
	}

	.es-footer__mark {
		display: flex;
		height: 2rem;
		width: 2rem;
		align-items: center;
		justify-content: center;
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border);
		background-color: var(--color-surface-elevated);
		color: var(--color-primary);
	}

	.es-footer__icon {
		height: 1.35rem;
		width: 1.35rem;
	}

	.es-footer__name {
		font-weight: var(--font-weight-semibold);
	}

	.es-footer__title {
		margin-top: var(--space-3);
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-medium);
		color: var(--color-text);
	}

	.es-footer__motto {
		margin-top: var(--space-4);
		max-width: 20rem;
		font-size: var(--font-size-small);
		color: var(--color-text-muted);
	}

	.es-footer__heading {
		font-size: var(--font-size-small);
		font-weight: var(--font-weight-semibold);
		color: var(--color-text);
	}

	.es-footer__list {
		margin: var(--space-4) 0 0;
		padding: 0;
		list-style: none;
	}

	.es-footer__list > * + * {
		margin-top: var(--space-2);
	}

	.es-footer__link {
		font-size: var(--font-size-small);
		color: var(--color-text-muted);
		text-decoration: none;
	}

	.es-footer__link:hover {
		color: var(--color-accent);
	}

	.es-footer__bottom {
		display: flex;
		flex-direction: column;
		gap: var(--space-6);
		border-top: 1px solid var(--color-border-subtle);
		padding-block: var(--space-6);
	}

	.es-footer__social {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-4);
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.es-footer__meta {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		font-size: var(--font-size-small);
		color: var(--color-text-muted);
	}

	@media (min-width: 640px) {
		.es-footer__meta {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
		}
	}
</style>
