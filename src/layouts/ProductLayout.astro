---
import type { CollectionEntry } from 'astro:content';
import ContentDetailLayout from './ContentDetailLayout.astro';
import MetaItem from '../components/content/MetaItem.astro';
import { formatLabel } from '../lib/content';

interface Props {
	entry: CollectionEntry<'products'>;
}

const { entry } = Astro.props;
const { title, description, price, status, download, github, tags, coverImage } = entry.data;
---

<ContentDetailLayout
	title={title}
	description={description}
	collection="products"
	entry={entry}
	coverImage={coverImage}
	tags={tags}
	eyebrow="Product"
>
	<dl slot="meta" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
		<MetaItem label="Price" value={price} />
		<MetaItem label="Status" value={formatLabel(status)} />
		{
			download && (
				<MetaItem label="Download" value="Get resource" href={download} />
			)
		}
		{
			github && (
				<MetaItem label="GitHub" value="View repository" href={github} />
			)
		}
	</dl>
	<slot />
</ContentDetailLayout>
