---
import type { CollectionEntry } from 'astro:content';
import ContentDetailLayout from './ContentDetailLayout.astro';
import MetaItem from '../components/content/MetaItem.astro';
import TechnologyBadgeList from '../components/content/TechnologyBadgeList.astro';
import { formatDate, formatLabel } from '../lib/content';
import { getTagUrl } from '../lib/knowledge';

interface Props {
	entry: CollectionEntry<'projects'>;
}

const { entry } = Astro.props;
const {
	title,
	description,
	status,
	github,
	demo,
	technologies,
	difficulty,
	startDate,
	updatedDate,
	tags,
	coverImage,
} = entry.data;
---

<ContentDetailLayout
	title={title}
	description={description}
	collection="projects"
	entry={entry}
	coverImage={coverImage}
	tags={tags}
	eyebrow="Project"
>
	<dl slot="meta">
		<MetaItem label="Status" value={formatLabel(status)} />
		<MetaItem label="Difficulty" value={formatLabel(difficulty)} href={getTagUrl(difficulty)} />
		<MetaItem label="Started" value={formatDate(startDate)} />
		<MetaItem label="Updated" value={formatDate(updatedDate ?? startDate)} />
		{
			github && (
				<MetaItem label="GitHub" value="View repository" href={github} />
			)
		}
		{
			demo && (
				<MetaItem label="Demo" value="View demo" href={demo} />
			)
		}
	</dl>

	{
		technologies.length > 0 && (
			<TechnologyBadgeList slot="technologies" technologies={technologies} />
		)
	}

	<slot />
</ContentDetailLayout>
