---
import type { CollectionEntry } from 'astro:content';
import ContentDetailLayout from './ContentDetailLayout.astro';
import MetaItem from '../components/content/MetaItem.astro';
import { formatDate, formatLabel } from '../lib/content';
import { getTagUrl } from '../lib/knowledge';

interface Props {
	entry: CollectionEntry<'threat-hunts'>;
}

const { entry } = Astro.props;
const { title, description, huntDate, status, tools, hypothesis, difficulty, tags, coverImage } = entry.data;
---

<ContentDetailLayout
	title={title}
	description={description}
	collection="threat-hunts"
	entry={entry}
	coverImage={coverImage}
	tags={tags}
	eyebrow="Threat Hunt"
>
	<dl slot="meta" class="grid gap-4 sm:grid-cols-2">
		<MetaItem label="Hunt Date" value={formatDate(huntDate)} />
		<MetaItem label="Status" value={formatLabel(status)} />
		<MetaItem label="Difficulty" value={formatLabel(difficulty)} href={getTagUrl(difficulty)} />
		<MetaItem label="Hypothesis" value={hypothesis} />
		{
			tools.length > 0 && (
				<MetaItem label="Tools" value={tools.join(', ')} />
			)
		}
	</dl>
	<slot />
</ContentDetailLayout>
