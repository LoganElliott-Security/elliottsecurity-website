---
import type { CollectionEntry } from 'astro:content';
import ContentDetailLayout from './ContentDetailLayout.astro';
import MetaItem from '../components/content/MetaItem.astro';
import TechnologyBadgeList from '../components/content/TechnologyBadgeList.astro';
import { formatDate, formatLabel } from '../lib/content';
import { getTagUrl } from '../lib/knowledge';

interface Props {
	entry: CollectionEntry<'homelab'>;
}

const { entry } = Astro.props;
const { title, description, category, platform, difficulty, technologies, updatedDate, tags, coverImage } =
	entry.data;
---

<ContentDetailLayout
	title={title}
	description={description}
	collection="homelab"
	entry={entry}
	coverImage={coverImage}
	tags={tags}
	eyebrow="Homelab"
>
	<div slot="meta" class="homelab-meta">
		<dl class="homelab-meta__grid">
			<MetaItem label="Category" value={category} href={getTagUrl(category)} />
			<MetaItem label="Platform" value={platform} href={getTagUrl(platform)} />
			<MetaItem label="Difficulty" value={formatLabel(difficulty)} href={getTagUrl(difficulty)} />
			<MetaItem label="Updated" value={formatDate(updatedDate)} />
		</dl>

		{
			technologies.length > 0 && (
				<div class="homelab-meta__technologies">
					<p class="homelab-meta__label">Technologies</p>
					<TechnologyBadgeList technologies={technologies} />
				</div>
			)
		}
	</div>

	<slot />
</ContentDetailLayout>

<style>
	.homelab-meta {
		display: flex;
		flex-direction: column;
		gap: var(--space-6);
	}

	.homelab-meta__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: var(--space-4) var(--space-6);
		margin: 0;
	}

	@media (min-width: 1024px) {
		.homelab-meta__grid {
			grid-template-columns: repeat(4, minmax(0, 1fr));
		}
	}

	.homelab-meta__technologies {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	.homelab-meta__label {
		margin: 0;
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-wide);
		text-transform: uppercase;
		color: var(--color-text-muted);
	}
</style>
