---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/content/Breadcrumbs.astro';
import MitreTechniqueList from '../components/content/MitreTechniqueList.astro';
import RelatedContentSections from '../components/content/RelatedContentSections.astro';
import StructuredData from '../components/seo/StructuredData.astro';
import TagList from '../components/content/TagList.astro';
import CoverImage from '../components/ui/CoverImage.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import { COLLECTION_ROUTES, type ContentCollectionName } from '../types/content';
import { getEntryUrl } from '../lib/content';
import {
	getDetailPageRelatedSections,
	getMitreTechniques,
} from '../lib/knowledge';
import {
	buildBreadcrumbSchema,
	buildDetailBreadcrumbs,
	buildTechArticleSchema,
	buildWebPageSchema,
} from '../lib/structured-data';

interface Props {
	title: string;
	description: string;
	collection: ContentCollectionName;
	entry: CollectionEntry<ContentCollectionName>;
	seoTitle?: string;
	seoDescription?: string;
	coverImage?: string;
	tags?: string[];
	eyebrow?: string;
}

const {
	title,
	description,
	collection,
	entry,
	seoTitle,
	seoDescription,
	coverImage,
	tags = [],
	eyebrow,
} = Astro.props;

const route = COLLECTION_ROUTES[collection];
const pageUrl = getEntryUrl(collection, entry);
const related = await getDetailPageRelatedSections(collection, entry);
const mitreTechniques = getMitreTechniques(collection, entry);
const breadcrumbs = buildDetailBreadcrumbs(collection, entry, route.label, route.path);
const webPageSchema = buildWebPageSchema({
	title: seoTitle ?? title,
	description: seoDescription ?? description,
	url: pageUrl,
});
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs);
const articleSchema = buildTechArticleSchema(collection, entry);
const structuredData = [webPageSchema, breadcrumbSchema, articleSchema].filter(
	(item): item is NonNullable<typeof articleSchema> => item !== null,
);
---

<BaseLayout
	title={seoTitle ?? title}
	description={seoDescription ?? description}
	image={coverImage}
>
	<StructuredData slot="head" data={structuredData} />
	<Section background="default" padding={true}>
		<Container size="narrow">
			<article>
				<Breadcrumbs items={breadcrumbs} />

				<header class="mb-10 border-b border-border-subtle pb-8">
					{eyebrow && (
						<p class="mb-3 text-sm font-medium uppercase tracking-widest text-accent">{eyebrow}</p>
					)}
					{coverImage && (
						<CoverImage src={coverImage} alt={`Cover image for ${title}`} class="mb-8 max-h-80" />
					)}
					<h1 class="text-balance text-foreground">{title}</h1>
					<p class="mt-4 text-lg">{description}</p>
					<div class="mt-6">
						<slot name="meta" />
					</div>
					{tags.length > 0 && <TagList tags={tags} class="mt-6" />}
					{mitreTechniques.length > 0 && <MitreTechniqueList techniques={mitreTechniques} class="mt-8" />}
				</header>

				<div class="content-prose">
					<slot />
				</div>

				<RelatedContentSections
					all={related.all}
					articles={related.articles}
					projects={related.projects}
					threatHunts={related.threatHunts}
					detections={related.detections}
					homelab={related.homelab}
				/>
			</article>
		</Container>
	</Section>
</BaseLayout>
