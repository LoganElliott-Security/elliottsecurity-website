---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/content/Breadcrumbs.astro';
import MitreTechniqueList from '../components/content/MitreTechniqueList.astro';
import RelatedContentSections from '../components/content/RelatedContentSections.astro';
import StructuredData from '../components/seo/StructuredData.astro';
import TagList from '../components/content/TagList.astro';
import CoverImage from '../components/ui/CoverImage.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import { COLLECTION_ROUTES, type ContentCollectionName } from '../types/content';
import { getEntryUrl } from '../lib/content';
import { resolveCoverImage } from '../lib/cover-image';
import {
	getDetailPageRelatedSections,
	getMitreTechniques,
} from '../lib/knowledge';
import {
	buildBreadcrumbSchema,
	buildDetailBreadcrumbs,
	buildTechArticleSchema,
	buildWebPageSchema,
} from '../lib/structured-data';

interface Props {
	title: string;
	description: string;
	collection: ContentCollectionName;
	entry: CollectionEntry<ContentCollectionName>;
	seoTitle?: string;
	seoDescription?: string;
	coverImage?: string;
	tags?: string[];
	eyebrow?: string;
}

const {
	title,
	description,
	collection,
	entry,
	seoTitle,
	seoDescription,
	coverImage,
	tags = [],
	eyebrow,
} = Astro.props;

const resolvedCoverImage = resolveCoverImage(coverImage);
const route = COLLECTION_ROUTES[collection];
const pageUrl = getEntryUrl(collection, entry);
const related = await getDetailPageRelatedSections(collection, entry);
const mitreTechniques = getMitreTechniques(collection, entry);
const breadcrumbs = buildDetailBreadcrumbs(collection, entry, route.label, route.path);
const webPageSchema = buildWebPageSchema({
	title: seoTitle ?? title,
	description: seoDescription ?? description,
	url: pageUrl,
});
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs);
const articleSchema = buildTechArticleSchema(collection, entry);
const structuredData = [webPageSchema, breadcrumbSchema, articleSchema].filter(
	(item): item is NonNullable<typeof articleSchema> => item !== null,
);
---

<BaseLayout
	title={seoTitle ?? title}
	description={seoDescription ?? description}
	image={resolvedCoverImage}
>
	<StructuredData slot="head" data={structuredData} />
	<Section background="default" padding={true}>
		<Container size="narrow">
			<article>
				<Breadcrumbs items={breadcrumbs} />

				<header class="content-hero">
					{eyebrow && <p class="content-hero__eyebrow">{eyebrow}</p>}

					<h1 class="content-hero__title text-balance">{title}</h1>

					{
						Astro.slots.has('meta') && (
							<div class="content-hero__meta">
								<slot name="meta" />
							</div>
						)
					}

					<p class="content-hero__description">{description}</p>

					{
						Astro.slots.has('technologies') && (
							<div class="content-hero__technologies">
								<p class="content-hero__section-label">Technologies</p>
								<slot name="technologies" />
							</div>
						)
					}

					{
						tags.length > 0 && (
							<div class="content-hero__tags">
								<p class="content-hero__section-label">Tags</p>
								<TagList tags={tags} />
							</div>
						)
					}

					{
						mitreTechniques.length > 0 && (
							<div class="content-hero__mitre">
								<MitreTechniqueList techniques={mitreTechniques} />
							</div>
						)
					}

					{
						resolvedCoverImage && (
							<div class="content-hero__cover">
								<CoverImage src={resolvedCoverImage} alt={`Cover image for ${title}`} />
							</div>
						)
					}
				</header>

				<div class="content-prose">
					<slot />
				</div>

				<RelatedContentSections
					all={related.all}
					articles={related.articles}
					projects={related.projects}
					threatHunts={related.threatHunts}
					detections={related.detections}
					homelab={related.homelab}
				/>
			</article>
		</Container>
	</Section>
</BaseLayout>

<style>
	.content-hero {
		display: flex;
		flex-direction: column;
		gap: var(--space-6);
		margin-bottom: var(--space-12);
		border-bottom: 1px solid var(--color-border-subtle);
		padding-bottom: var(--space-10);
	}

	.content-hero__eyebrow {
		margin: 0;
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-widest);
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.content-hero__title {
		margin: 0;
		color: var(--color-text);
	}

	.content-hero__description {
		margin: 0;
		max-width: 42rem;
		font-size: var(--font-size-body-lg);
		line-height: var(--line-height-relaxed);
		color: var(--color-text-secondary);
	}

	.content-hero__meta {
		display: block;
	}

	.content-hero__meta :global(dl) {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: var(--space-4) var(--space-6);
		margin: 0;
	}

	@media (min-width: 1024px) {
		.content-hero__meta :global(dl) {
			grid-template-columns: repeat(4, minmax(0, 1fr));
		}
	}

	.content-hero__section-label {
		margin: 0 0 var(--space-2);
		font-size: var(--font-size-caption);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-wide);
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	.content-hero__technologies,
	.content-hero__tags,
	.content-hero__mitre {
		display: flex;
		flex-direction: column;
	}

	.content-hero__cover {
		margin-top: var(--space-2);
	}
</style>
