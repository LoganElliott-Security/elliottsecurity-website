---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import Navigation from '../components/Navigation.astro';
import SEO from '../components/SEO.astro';
import StructuredData from '../components/seo/StructuredData.astro';
import { SITE } from '../config/site';
import { getGlobalStructuredData } from '../lib/structured-data';
import { getCanonicalUrl, getSeoMetadata, type SeoInput } from '../lib/seo';

interface Props extends SeoInput {
	title?: string;
}

const { title, description, image, noindex } = Astro.props;
const canonical = getCanonicalUrl(Astro.url.pathname);
const seo = getSeoMetadata({ title, description, image, canonical, noindex });
const globalStructuredData = getGlobalStructuredData();
---

<!doctype html>
<html lang={SITE.locale}>
	<head>
		<SEO
			title={title}
			description={description}
			image={image}
			canonical={canonical}
			noindex={noindex}
		/>
		<title>{seo.title}</title>
		<StructuredData data={globalStructuredData} />
		<slot name="head" />
	</head>
	<body class="site-body bg-atmosphere" data-theme="dark">
		<a href="#main-content" class="skip-link">
			Skip to main content
		</a>
		<Navigation />
		<main id="main-content" class="site-main">
			<slot />
		</main>
		<Footer />
	</body>

	<style>
		.site-body {
			display: flex;
			min-height: 100vh;
			flex-direction: column;
		}

		.site-main {
			flex: 1;
		}

		.skip-link {
			position: absolute;
			width: 1px;
			height: 1px;
			padding: 0;
			margin: -1px;
			overflow: hidden;
			clip: rect(0, 0, 0, 0);
			white-space: nowrap;
			border-width: 0;
		}

		.skip-link:focus {
			position: absolute;
			left: var(--space-4);
			top: var(--space-4);
			z-index: var(--z-max);
			width: auto;
			height: auto;
			margin: 0;
			overflow: visible;
			clip: auto;
			border-radius: var(--radius-md);
			background-image: var(--gradient-primary);
			padding: var(--space-2) var(--space-4);
			color: var(--color-primary-foreground);
			white-space: normal;
			outline: 2px solid var(--color-ring);
			outline-offset: 2px;
		}
	</style>
</html>
