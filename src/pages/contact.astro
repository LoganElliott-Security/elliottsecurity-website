---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/content/Breadcrumbs.astro';
import ContactCardGrid from '../components/profile/ContactCardGrid.astro';
import StructuredData from '../components/seo/StructuredData.astro';
import Button from '../components/ui/Button.astro';
import Container from '../components/ui/Container.astro';
import { RESUME_PATH, SEO } from '../config/profile';
import { buildBreadcrumbSchema, buildListingBreadcrumbs, buildPersonSchema, buildWebPageSchema } from '../lib/structured-data';

const breadcrumbs = buildListingBreadcrumbs(SEO.contact.title, '/contact');
---

<BaseLayout title={SEO.contact.title} description={SEO.contact.description}>
	<StructuredData
		slot="head"
		data={[
			buildWebPageSchema({ title: SEO.contact.title, description: SEO.contact.description, url: '/contact' }),
			buildBreadcrumbSchema(breadcrumbs),
			buildPersonSchema(),
		]}
	/>
	<section class="page-hero">
		<div class="page-hero__glow" aria-hidden="true"></div>
		<Container size="narrow" class="page-hero__content">
			<Breadcrumbs items={breadcrumbs} />
			<header class="page-hero__header">
				<p class="type-eyebrow">Contact</p>
				<h1 class="type-h1 text-balance">Let's Connect</h1>
				<p class="page-hero__lead">
					Interested in cybersecurity engineering, detection engineering, threat hunting, DFIR, or collaborative
					research? Feel free to reach out.
				</p>
				<div class="page-hero__actions">
					<Button href={RESUME_PATH} size="lg" download>
						Download Resume
					</Button>
				</div>
			</header>
			<ContactCardGrid size="large" />
		</Container>
	</section>

	<style>
		.page-hero {
			position: relative;
			overflow: hidden;
			padding-block: var(--space-section-sm);
		}

		@media (min-width: 640px) {
			.page-hero {
				padding-block: var(--space-section);
			}
		}

		.page-hero__glow {
			pointer-events: none;
			position: absolute;
			inset: 0;
			background-image: var(--gradient-hero), var(--gradient-glow);
			background-repeat: no-repeat;
		}

		.page-hero__content {
			position: relative;
		}

		.page-hero__header {
			margin-bottom: var(--space-12);
			text-align: center;
		}

		.page-hero__header .type-eyebrow {
			margin-bottom: var(--space-4);
		}

		.page-hero__lead {
			margin-inline: auto;
			margin-top: var(--space-6);
			max-width: 42rem;
			font-size: var(--font-size-body-lg);
			line-height: var(--line-height-relaxed);
			color: var(--color-text-secondary);
		}

		.page-hero__actions {
			margin-top: var(--space-8);
		}
	</style>
</BaseLayout>
