---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/content/Breadcrumbs.astro';
import NowSections from '../components/profile/NowSections.astro';
import StructuredData from '../components/seo/StructuredData.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import { NOW_SECTIONS, NOW_UPDATED } from '../config/now';
import { PROFILE, SEO } from '../config/profile';
import { buildBreadcrumbSchema, buildListingBreadcrumbs, buildWebPageSchema } from '../lib/structured-data';
import { formatDate } from '../lib/content';

const breadcrumbs = buildListingBreadcrumbs(SEO.now.title, '/now');
const updatedLabel = formatDate(new Date(NOW_UPDATED));
---

<BaseLayout title={SEO.now.title} description={SEO.now.description}>
	<StructuredData
		slot="head"
		data={[
			buildWebPageSchema({ title: SEO.now.title, description: SEO.now.description, url: '/now' }),
			buildBreadcrumbSchema(breadcrumbs),
		]}
	/>
	<Section background="default" padding={true}>
		<Container size="narrow">
			<Breadcrumbs items={breadcrumbs} />
			<SectionHeader
				eyebrow="Now"
				title="What I'm Working On"
				description={`Current engineering priorities for ${PROFILE.name} — detection engineering lab work, threat hunting, DFIR research, and platform publishing.`}
			/>
			<p class="mb-10 text-sm text-muted-foreground">Last updated: {updatedLabel}</p>
			<NowSections sections={NOW_SECTIONS} />
		</Container>
	</Section>
</BaseLayout>
