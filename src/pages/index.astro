---
import BaseLayout from '../layouts/BaseLayout.astro';
import StructuredData from '../components/seo/StructuredData.astro';
import CurrentFocusGrid from '../components/profile/CurrentFocusGrid.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import { CURRENT_FOCUS, PLATFORM_TOPICS, PROFILE, SEO } from '../config/profile';
import { getSocialProfile } from '../config/social';
import { buildPersonSchema, buildWebPageSchema } from '../lib/structured-data';

const githubUrl = getSocialProfile('github')?.href ?? 'https://github.com/LoganElliott-Security';
---

<BaseLayout title={SEO.homepage.title} description={SEO.homepage.description}>
	<title slot="head">{SEO.homepage.title}</title>
	<StructuredData
		slot="head"
		data={[
			buildWebPageSchema({
				title: SEO.homepage.title,
				description: SEO.homepage.description,
				url: '/',
			}),
			buildPersonSchema(),
		]}
	/>
	<Section background="default" padding={true} class="relative overflow-hidden">
		<div
			class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(34,211,238,0.08)_0%,_transparent_50%)]"
			aria-hidden="true"
		>
		</div>
		<Container class="relative">
			<div class="mx-auto max-w-4xl text-center">
				<p class="mb-4 text-sm font-medium uppercase tracking-widest text-accent">Cybersecurity Engineering</p>
				<h1 class="text-balance text-foreground">{PROFILE.name}, {PROFILE.credential}</h1>
				<div class="mt-6 space-y-1 text-base font-medium text-muted sm:text-lg">
					{PROFILE.titles.map((title) => <p>{title}</p>)}
				</div>
				<p class="mx-auto mt-4 max-w-2xl text-sm text-muted-foreground">{PROFILE.headline}</p>
				<p class="mx-auto mt-8 max-w-2xl text-lg leading-relaxed sm:text-xl">{PROFILE.tagline}</p>
				<div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
					<Button href="/projects" size="lg">View Projects</Button>
					<Button href="/detection-engineering" size="lg" variant="outline">View Detection Engineering</Button>
				</div>
				<div class="mt-4">
					<Button href={githubUrl} variant="ghost" size="md">View GitHub</Button>
				</div>
			</div>
		</Container>
	</Section>

	<Section id="current-focus" background="muted">
		<Container>
			<SectionHeader
				eyebrow="Current Focus"
				title="Current Focus"
				description="Active engineering priorities across detection engineering, threat hunting, DFIR, and lab infrastructure."
			/>
			<CurrentFocusGrid items={CURRENT_FOCUS} columns={3} />
		</Container>
	</Section>

	<Section id="platform">
		<Container>
			<SectionHeader
				eyebrow="Platform"
				title="ElliottSecurity Platform"
				description="A static, Markdown-driven cybersecurity knowledge platform for publishing real engineering work."
			/>
			<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
				{
					PLATFORM_TOPICS.map((topic) => (
						<Card padding="md" class="h-full">
							<h3 class="text-lg font-semibold text-foreground">{topic}</h3>
							<p class="mt-3 text-sm leading-relaxed">
								Documenting {topic.toLowerCase()} work from enterprise operations and lab engineering.
							</p>
						</Card>
					))
				}
			</div>
		</Container>
	</Section>
</BaseLayout>
