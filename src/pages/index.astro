---
import BaseLayout from '../layouts/BaseLayout.astro';
import StructuredData from '../components/seo/StructuredData.astro';
import EngineeringProjectCard from '../components/focus/EngineeringProjectCard.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import { getHomepagePriorities } from '../config/currentFocus';
import { PLATFORM_TOPICS, PROFILE, SEO } from '../config/profile';
import { getSocialProfile } from '../config/social';
import { buildPersonSchema, buildWebPageSchema } from '../lib/structured-data';

const githubUrl = getSocialProfile('github')?.href ?? 'https://github.com/LoganElliott-Security';
const homepagePriorities = getHomepagePriorities(3);
---

<BaseLayout title={SEO.homepage.title} description={SEO.homepage.description}>
	<title slot="head">{SEO.homepage.title}</title>
	<StructuredData
		slot="head"
		data={[
			buildWebPageSchema({
				title: SEO.homepage.title,
				description: SEO.homepage.description,
				url: '/',
			}),
			buildPersonSchema(),
		]}
	/>

	<section class="hero">
		<div class="hero__glow" aria-hidden="true"></div>
		<Container class="hero__content">
			<p class="type-eyebrow animate-fade-in">Cybersecurity Engineering</p>
			<h1 class="hero__title type-display animate-slide-up">
				{PROFILE.name}<span class="hero__credential">, {PROFILE.credential}</span>
			</h1>
			<div class="hero__titles animate-slide-up-delay-1">
				{PROFILE.titles.map((title) => <p>{title}</p>)}
			</div>
			<p class="hero__headline animate-slide-up-delay-1">{PROFILE.headline}</p>
			<p class="hero__tagline type-body-lg animate-slide-up-delay-2">{PROFILE.tagline}</p>
			<div class="hero__actions animate-slide-up-delay-2">
				<Button href="/projects" size="lg">View Projects</Button>
				<Button href="/detection-engineering" size="lg" variant="outline">View Detection Engineering</Button>
				<Button href={githubUrl} variant="ghost" size="md">View GitHub</Button>
			</div>
		</Container>
	</section>

	<Section id="current-focus" background="secondary">
		<SectionHeader
			eyebrow="Current Focus"
			title="Current Focus"
			description="Top active engineering priorities — detection lab, platform development, and threat hunting research."
			actionLabel="View full dashboard"
			actionHref="/current-focus"
		/>
		<ul class="home-grid home-grid--focus" role="list">
			{homepagePriorities.map((project) => (
				<li>
					<EngineeringProjectCard project={project} />
				</li>
			))}
		</ul>
	</Section>

	<Section id="platform">
		<SectionHeader
			eyebrow="Platform"
			title="ElliottSecurity Platform"
			description="A static, Markdown-driven cybersecurity knowledge platform for publishing real engineering work."
		/>
		<div class="home-grid home-grid--topics">
			{
				PLATFORM_TOPICS.map((topic) => (
					<Card padding="lg" hover={true} class="topic-card">
						<h3 class="type-h4">{topic}</h3>
						<p class="topic-card__body">
							Documenting {topic.toLowerCase()} work from enterprise operations and lab engineering.
						</p>
					</Card>
				))
			}
		</div>
	</Section>
</BaseLayout>

<style>
	.hero {
		position: relative;
		overflow: hidden;
		padding-block: var(--space-20) var(--space-24);
	}

	@media (min-width: 640px) {
		.hero {
			padding-block: var(--space-24) var(--space-24);
		}
	}

	.hero__glow {
		pointer-events: none;
		position: absolute;
		inset: 0;
		background-image: var(--gradient-hero), var(--gradient-glow), var(--gradient-vignette);
		background-repeat: no-repeat;
	}

	.hero__content {
		position: relative;
		max-width: var(--container-narrow);
		margin-inline: auto;
		text-align: center;
	}

	.hero__title {
		margin-top: var(--space-4);
		text-wrap: balance;
	}

	.hero__credential {
		color: var(--color-soft);
		font-weight: var(--font-weight-semibold);
	}

	.hero__titles {
		margin-top: var(--space-6);
		display: flex;
		flex-direction: column;
		gap: var(--space-1);
		font-size: var(--font-size-body);
		font-weight: var(--font-weight-medium);
		color: var(--color-text-secondary);
	}

	@media (min-width: 640px) {
		.hero__titles {
			font-size: var(--font-size-body-lg);
		}
	}

	.hero__headline {
		margin-inline: auto;
		margin-top: var(--space-4);
		max-width: 42rem;
		font-size: var(--font-size-small);
		color: var(--color-text-muted);
	}

	.hero__tagline {
		margin-inline: auto;
		margin-top: var(--space-8);
		max-width: 42rem;
		color: var(--color-text-secondary);
	}

	.hero__actions {
		margin-top: var(--space-10);
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: var(--space-4);
	}

	@media (min-width: 640px) {
		.hero__actions {
			flex-direction: row;
			flex-wrap: wrap;
		}
	}

	.home-grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: var(--space-6);
	}

	.home-grid--focus {
		gap: var(--space-4);
	}

	@media (min-width: 768px) {
		.home-grid--focus {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.home-grid--topics {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.home-grid--topics {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.topic-card {
		height: 100%;
	}

	.topic-card__body {
		margin-top: var(--space-3);
		font-size: var(--font-size-small);
		line-height: var(--line-height-relaxed);
		color: var(--color-text-muted);
	}
</style>
