---
import ContentCard from '../../components/content/ContentCard.astro';
import CollectionListingLayout from '../../layouts/CollectionListingLayout.astro';
import { formatDate, getEntryUrl, getPublishedCollection, sortByDateDesc } from '../../lib/content';

const entries = sortByDateDesc(await getPublishedCollection('homelab'), 'updatedDate');
---

<CollectionListingLayout
	eyebrow="Homelab"
	title="Homelab"
	description="Infrastructure and lab documentation for detection engineering and research."
	path="/homelab"
	isEmpty={entries.length === 0}
	emptyTitle="Homelab documentation coming soon."
	emptyDescription="Lab architecture and engineering notes will be published here."
>
	{
		entries.map((entry) => (
			<ContentCard
				title={entry.data.title}
				description={entry.data.description}
				href={getEntryUrl('homelab', entry)}
				meta={formatDate(entry.data.updatedDate)}
				tags={entry.data.tags}
				coverImage={entry.data.coverImage}
			/>
		))
	}
</CollectionListingLayout>
