---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/content/Breadcrumbs.astro';
import StructuredData from '../../components/seo/StructuredData.astro';
import EmptyState from '../../components/ui/EmptyState.astro';
import Section from '../../components/ui/Section.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import { getTagIndex, getTagUrl } from '../../lib/knowledge';
import { buildBreadcrumbSchema, buildWebPageSchema } from '../../lib/structured-data';

const tags = await getTagIndex();
const breadcrumbs = [
	{ name: 'Home', path: '/' },
	{ name: 'Tags', path: '/tags' },
];
---

<BaseLayout title="Tags" description="Browse ElliottSecurity Platform content by tag, technique, technology, and metadata.">
	<StructuredData
		slot="head"
		data={[
			buildWebPageSchema({
				title: 'Tags',
				description: 'Browse ElliottSecurity Platform content by tag, technique, technology, and metadata.',
				url: '/tags',
			}),
			buildBreadcrumbSchema(breadcrumbs),
		]}
	/>
	<Section background="default" padding={true}>
		<Breadcrumbs items={breadcrumbs} />
		<SectionHeader
			eyebrow="Knowledge"
			title="Tags"
			description="Explore related content across articles, projects, threat hunts, detections, homelab, and products."
		/>
		<ul class="tag-index" role="list">
			{
				tags.length > 0 ? (
					tags.map((tag) => (
						<li>
							<a href={getTagUrl(tag.label)} class="tag-index__link">
								<span>{tag.label}</span>
								<span class="tag-index__count">({tag.count})</span>
							</a>
						</li>
					))
				) : (
					<li class="tag-index__empty">
						<EmptyState
							title="No tags yet"
							description="Tags are generated automatically from published content metadata."
						/>
					</li>
				)
			}
		</ul>
	</Section>
</BaseLayout>

<style>
	.tag-index {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.tag-index__link {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		border-radius: var(--radius-pill);
		border: 1px solid var(--color-border);
		background-color: var(--color-surface-muted);
		padding: var(--space-1) var(--space-3);
		font-size: var(--font-size-small);
		color: var(--color-text-secondary);
		text-decoration: none;
		transition: var(--transition-hover);
	}

	.tag-index__link:hover {
		border-color: color-mix(in srgb, var(--color-primary) 40%, var(--color-border));
		color: var(--color-accent);
		background-color: var(--color-primary-muted);
	}

	.tag-index__count {
		font-size: var(--font-size-caption);
		color: var(--color-text-muted);
	}

	.tag-index__empty {
		width: 100%;
	}
</style>
